---
/*
 * Layout comparison sandbox (/layouts) — not linked from nav.
 *
 * Renders the REAL, full FieldForce case study (same <CaseStudy> component
 * and data as /work/fieldforce) and lets you flip it between three layouts
 * via a sticky switcher. The layout modes are real classes on the component
 * (.case-study--wide / --multicol / --twopane), so whichever you pick is
 * already implemented — applying it for real is just setting that class.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import CaseStudy from "../components/CaseStudy.astro";
import { getCaseStudy } from "../data/caseStudies";

const cs = getCaseStudy("fieldforce");
---

<BaseLayout title="Layout comparison — sandbox" description="Internal layout sandbox.">
  <div class="switcher" role="group" aria-label="Layout version">
    <span class="switcher-label">Layout:</span>
    <button type="button" data-mode="wide">A · Wide single column</button>
    <button type="button" data-mode="multicol" class="is-active">B · Multi-column</button>
    <button type="button" data-mode="twopane">C · Two-pane sidebar</button>
  </div>

  {cs && (
    <CaseStudy
      title={cs.title}
      tagline={cs.tagline}
      availability={cs.availability}
      problem={cs.problem}
      approach={cs.approach}
      status={cs.status}
      techStack={cs.techStack}
      repoUrl={cs.repoUrl}
      features={cs.features}
      techDecisions={cs.techDecisions}
      role={cs.role}
      architectureDiagramUrl={cs.architectureDiagramUrl}
      architectureDiagramAlt={cs.architectureDiagramAlt}
      screenshots={cs.screenshots}
      downloads={cs.downloads}
    />
  )}
</BaseLayout>

<script>
  (() => {
    const panel = document.querySelector<HTMLElement>(".case-study");
    const buttons = document.querySelectorAll<HTMLButtonElement>(".switcher button");
    if (!panel) return;
    // Start in the default (multi-column) mode.
    panel.classList.add("case-study--multicol");
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        panel.classList.remove(
          "case-study--wide",
          "case-study--multicol",
          "case-study--twopane",
        );
        panel.classList.add(`case-study--${btn.dataset.mode}`);
        buttons.forEach((b) => b.classList.toggle("is-active", b === btn));
      });
    });
  })();
</script>

<style>
  /* This sandbox needs the full viewport width, not the 1200px main cap. */
  :global(main) {
    max-width: 100% !important;
    padding-left: clamp(16px, 3vw, 48px);
    padding-right: clamp(16px, 3vw, 48px);
  }

  .switcher {
    position: sticky;
    top: 12px;
    z-index: 50;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-bottom: var(--space-2xl);
    padding: 12px 16px;
    border-radius: var(--radius-lg);
    background: var(--glass-bg-hover);
    border: 1px solid var(--glass-border-strong);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }
  .switcher-label {
    font-family: var(--font-ui);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-fg-tertiary);
  }
  .switcher button {
    font-family: var(--font-ui);
    font-size: 14px;
    padding: 8px 16px;
    border-radius: 999px;
    border: 1px solid var(--glass-border);
    background: transparent;
    color: var(--color-fg-secondary);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .switcher button:hover {
    color: var(--color-fg-primary);
    background: var(--glass-bg);
  }
  .switcher button.is-active {
    color: white;
    background: var(--accent-royal);
    border-color: var(--accent-royal-bright);
  }
</style>
