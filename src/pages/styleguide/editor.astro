---
/**
 * Prism Editor — Phase 2 control surface.
 *
 * Two-column page (sticky control sidebar + live preview canvas) that lets
 * the user point-and-click every token in the Phase 1 design system. The
 * sidebar drives a single EditorState managed by `prism-editor-store.ts`;
 * every change is debounced into localStorage and re-applied to the
 * preview canvas in real time.
 *
 * The preview canvas mirrors the Phase 1 styleguide's main token-exercising
 * sections (color tokens, typography, layout primitives, glass components,
 * brand wordmark) so the user sees an end-to-end effect of any change.
 *
 * Scope guardrails (per spec):
 *   - Only two new files. This page + src/lib/prism-editor-store.ts.
 *   - No edits to tokens.css, prism-palette.ts, prism-runtime.ts,
 *     prismSwatches.ts, the styleguide index or swatches page, or
 *     BaseLayout.
 *   - Optional TokenUsage component (Agent C) is feature-detected; the
 *     page renders fine without it.
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import Stack from "../../components/Stack.astro";
import Grid from "../../components/Grid.astro";
import GlassPanel from "../../components/GlassPanel.astro";
import GlassButton from "../../components/GlassButton.astro";
import GlassInput from "../../components/GlassInput.astro";
import GlassField from "../../components/GlassField.astro";
import GlassTextarea from "../../components/GlassTextarea.astro";
import TokenUsage from "../../components/TokenUsage.astro";
import { swatches, isMono, formatMonoOklch } from "../../data/prismSwatches";

const modes = [
  { id: "dark",       label: "Dark" },
  { id: "light",      label: "Light" },
  { id: "hybrid",     label: "Hybrid" },
  { id: "system",     label: "System" },
  { id: "neomorphic", label: "Neo" },
] as const;

const mixingModels = [
  { id: "analogous",           label: "Analogous" },
  { id: "split-complementary", label: "Split-comp" },
  { id: "complementary",       label: "Complement" },
] as const;

// Token groups for the per-token color picker section. The order matches
// the spec; rows are rendered with both a hex `<input type="color">` and
// a togglable OKLCH triple of L / C / h numeric inputs.
const tokenGroups = [
  {
    id: "bg",
    label: "Backgrounds",
    tokens: [
      "--bg-1", "--bg-2", "--bg-3", "--bg-4",
      "--bg-overlay-1", "--bg-overlay-2",
    ],
  },
  {
    id: "accent-royal",
    label: "Accent (royal)",
    tokens: ["--accent-royal", "--accent-royal-bright", "--accent-royal-deep"],
  },
  {
    id: "accent-emerald",
    label: "Accent (emerald)",
    tokens: ["--accent-emerald", "--accent-emerald-bright", "--accent-emerald-deep"],
  },
  {
    id: "fg",
    label: "Foreground",
    tokens: [
      "--color-fg-primary", "--color-fg-secondary",
      "--color-fg-tertiary", "--color-fg-muted",
    ],
  },
  {
    id: "brand",
    label: "Brand",
    tokens: ["--brand-color", "--brand-glow"],
  },
  {
    id: "glass",
    label: "Glass",
    tokens: ["--glass-bg", "--glass-bg-hover", "--glass-border", "--glass-border-strong"],
  },
] as const;

// Quick-select swatches. We pick the 8 mono swatches the user is most
// likely to want as starting points so the row stays scannable.
const quickSwatches = swatches.filter(isMono).slice(0, 8);

// Read-only display tokens for the Spacing & Radius card.
const spacingTokens = [
  { name: "--space-2xs", value: "0.25rem" },
  { name: "--space-xs",  value: "0.5rem" },
  { name: "--space-sm",  value: "0.75rem" },
  { name: "--space-md",  value: "1rem" },
  { name: "--space-lg",  value: "1.5rem" },
  { name: "--space-xl",  value: "2rem" },
  { name: "--space-2xl", value: "3rem" },
];

const radiusTokens = [
  { name: "--radius-sm",   value: "8px" },
  { name: "--radius-md",   value: "16px" },
  { name: "--radius-lg",   value: "24px" },
  { name: "--radius-xl",   value: "36px" },
  { name: "--radius-full", value: "9999px" },
];

// Preview canvas token grid (mirrors styleguide/index.astro's color block).
const previewColorTokens = [
  { name: "--bg-1",                  desc: "Background gradient stop 1" },
  { name: "--bg-2",                  desc: "Background gradient stop 2" },
  { name: "--bg-3",                  desc: "Background gradient stop 3" },
  { name: "--bg-4",                  desc: "Background gradient stop 4" },
  { name: "--accent-royal",          desc: "Primary brand accent" },
  { name: "--accent-royal-bright",   desc: "Royal highlight" },
  { name: "--accent-royal-deep",     desc: "Royal pressed" },
  { name: "--accent-emerald",        desc: "Alternate accent" },
  { name: "--accent-emerald-bright", desc: "Emerald highlight" },
  { name: "--accent-emerald-deep",   desc: "Emerald pressed" },
  { name: "--color-fg-primary",      desc: "Primary body text" },
  { name: "--color-fg-secondary",    desc: "Secondary body text" },
  { name: "--brand-color",           desc: "Brand wordmark fill" },
  { name: "--brand-glow",            desc: "Brand wordmark glow" },
];
---

<BaseLayout
  title="Prism Editor — Phase 2"
  description="Point-and-click editor for the Prism design system. Edit every token live and watch the preview canvas update in real time.">

  <Container size="2xl">
    <div class="editor-shell">

      {/* ─── Mobile drawer toggle ─────────────────────────────────────── */}
      <button type="button" class="editor-mobile-toggle" data-editor-mobile-toggle aria-expanded="false" aria-controls="editor-sidebar">
        <span>Open editor controls</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="14" height="14">
          <path d="M3 6 L8 11 L13 6" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>

      {/* ─── Sidebar (controls) ───────────────────────────────────────── */}
      <aside id="editor-sidebar" class="editor-sidebar" data-editor-sidebar>
        <header class="editor-header">
          <p class="eyebrow">Prism design system</p>
          <h1 class="page-title">Editor</h1>
          <p class="sidebar-lede">Edit every token live. Changes auto-save.</p>
        </header>

        {/* Persistence row */}
        <div class="persistence-row" role="group" aria-label="Persistence">
          <button type="button" class="persistence-btn" data-editor-reset title="Clear all overrides and restore tokens.css defaults">
            Reset
          </button>
          <button type="button" class="persistence-btn" data-editor-export title="Save current state as prism-overrides.json">
            Export…
          </button>
          <button type="button" class="persistence-btn" data-editor-import title="Load a prism-overrides.json file">
            Import…
          </button>
        </div>
        <p class="persistence-status" data-editor-status aria-live="polite"></p>

        {/* ─── Section 1: Theme mode ─────────────────────────────── */}
        <details class="control-card" open>
          <summary class="control-card-summary">1. Theme mode</summary>
          <div class="control-card-body">
            <div class="segmented" role="radiogroup" aria-label="Theme mode">
              {modes.map((m) => (
                <button type="button" class="segment" role="radio" aria-checked="false" data-editor-mode={m.id}>
                  {m.label}
                </button>
              ))}
            </div>
          </div>
        </details>

        {/* ─── Section 2: Palette generator ─────────────────────── */}
        <details class="control-card" open>
          <summary class="control-card-summary">2. Palette generator</summary>
          <div class="control-card-body">
            <div class="field">
              <div class="field-row">
                <label class="field-label" for="editor-hue">Hue</label>
                <input
                  id="editor-hue-num"
                  type="number"
                  min="0"
                  max="360"
                  step="1"
                  class="field-numeric"
                  data-editor-hue-num
                />
              </div>
              <input
                id="editor-hue"
                type="range"
                min="0"
                max="360"
                step="1"
                class="hue-slider"
                data-editor-hue
                aria-label="Base hue"
              />
            </div>

            <div class="field">
              <label class="field-label" for="editor-model">Mixing model</label>
              <select id="editor-model" class="field-select" data-editor-model>
                {mixingModels.map((m) => (
                  <option value={m.id}>{m.label}</option>
                ))}
              </select>
            </div>

            <div class="field">
              <span class="field-label">Contrast</span>
              <div class="segmented" role="radiogroup" aria-label="Contrast level">
                <button type="button" class="segment" role="radio" aria-checked="false" data-editor-contrast="AA">AA</button>
                <button type="button" class="segment" role="radio" aria-checked="false" data-editor-contrast="AAA">AAA</button>
              </div>
            </div>

            <button type="button" class="generate-btn" data-editor-generate title="Re-run the palette generator with the current axis values">
              Generate
            </button>
          </div>
        </details>

        {/* ─── Section 3: Quick-select swatches ─────────────────── */}
        <details class="control-card" open>
          <summary class="control-card-summary">3. Quick-select swatches</summary>
          <div class="control-card-body">
            <div class="quick-swatch-grid">
              {quickSwatches.map((s) => (
                <button
                  type="button"
                  class="quick-swatch"
                  title={s.name}
                  aria-label={`Apply ${s.name}`}
                  data-editor-quick-swatch={s.id}
                  data-editor-quick-hue={String(s.oklch.h)}
                >
                  <span class="quick-swatch-chip" style={`background: ${formatMonoOklch(s)};`} aria-hidden="true" />
                  <span class="quick-swatch-name">{s.name}</span>
                </button>
              ))}
            </div>
          </div>
        </details>

        {/* ─── Section 4: Per-token color pickers ───────────────── */}
        <details class="control-card">
          <summary class="control-card-summary">4. Per-token colors</summary>
          <div class="control-card-body control-card-body--tight">
            {tokenGroups.map((g) => (
              <details class="token-group">
                <summary class="token-group-summary">{g.label}</summary>
                <div class="token-rows">
                  {g.tokens.map((token) => (
                    <div class="token-row" data-editor-token-row={token}>
                      <div class="token-row-head">
                        <code class="token-name">{token}</code>
                        <span class="token-preview" style={`background: var(${token});`} aria-hidden="true" />
                      </div>
                      <div class="token-row-controls">
                        <input
                          type="color"
                          class="token-color-input"
                          data-editor-token-color={token}
                          aria-label={`${token} hex picker`}
                          value="#888888"
                        />
                        <button
                          type="button"
                          class="token-toggle"
                          data-editor-token-oklch-toggle={token}
                          aria-expanded="false"
                          aria-label={`Toggle OKLCH editor for ${token}`}
                        >
                          OKLCH
                        </button>
                        <button
                          type="button"
                          class="token-clear"
                          data-editor-token-clear={token}
                          title="Remove this override"
                          aria-label={`Clear override for ${token}`}
                        >
                          ×
                        </button>
                      </div>
                      <div class="token-oklch-inputs" data-editor-token-oklch-fields={token} hidden>
                        <label class="oklch-field">
                          <span>L</span>
                          <input type="number" min="0" max="1" step="0.01" data-editor-token-l={token} />
                        </label>
                        <label class="oklch-field">
                          <span>C</span>
                          <input type="number" min="0" max="0.4" step="0.01" data-editor-token-c={token} />
                        </label>
                        <label class="oklch-field">
                          <span>h</span>
                          <input type="number" min="0" max="360" step="1" data-editor-token-h={token} />
                        </label>
                      </div>
                      <div class="token-usage-slot token-usage-slot--active" data-editor-token-usage={token}>
                        <TokenUsage token={token} />
                      </div>
                    </div>
                  ))}
                </div>
              </details>
            ))}
          </div>
        </details>

        {/* ─── Section 5: Effects ───────────────────────────────── */}
        <details class="control-card">
          <summary class="control-card-summary">5. Effects</summary>
          <div class="control-card-body">
            <div class="field">
              <div class="field-row">
                <label class="field-label" for="effect-blur">Glass blur</label>
                <span class="field-value" data-effect-blur-display>—</span>
              </div>
              <input id="effect-blur" type="range" min="0" max="24" step="1" data-editor-effect="--glass-blur" data-effect-unit="px" />
            </div>
            <div class="field">
              <div class="field-row">
                <label class="field-label" for="effect-saturate">Glass saturate</label>
                <span class="field-value" data-effect-saturate-display>—</span>
              </div>
              <input id="effect-saturate" type="range" min="50" max="200" step="5" data-editor-effect="--glass-saturate" data-effect-unit="%" />
            </div>
            <div class="field">
              <div class="field-row">
                <label class="field-label" for="effect-duration">Motion duration</label>
                <span class="field-value" data-effect-duration-display>—</span>
              </div>
              <input id="effect-duration" type="range" min="50" max="800" step="10" data-editor-effect="--duration-base" data-effect-unit="ms" />
            </div>
          </div>
        </details>

        {/* ─── Section 6: Spacing & Radius (read-only) ──────────── */}
        <details class="control-card">
          <summary class="control-card-summary">6. Spacing & radius (read-only)</summary>
          <div class="control-card-body">
            <p class="readonly-note">Phase 2 scope: display only. Editing arrives with Phase 3.</p>
            <div class="readonly-grid">
              <div>
                <p class="readonly-label">Spacing</p>
                {spacingTokens.map((t) => (
                  <div class="readonly-row">
                    <code class="readonly-token">{t.name}</code>
                    <span class="readonly-value">{t.value}</span>
                  </div>
                ))}
              </div>
              <div>
                <p class="readonly-label">Radius</p>
                {radiusTokens.map((t) => (
                  <div class="readonly-row">
                    <code class="readonly-token">{t.name}</code>
                    <span class="readonly-value">{t.value}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </details>
      </aside>

      {/* ─── Preview canvas ───────────────────────────────────────────── */}
      <section class="editor-preview" aria-label="Live preview">
        <Stack gap="2xl">
          <header>
            <Stack gap="xs">
              <p class="eyebrow">Live preview</p>
              <h2 class="preview-title">Prince Rehman</h2>
              <p class="preview-sub">P. R. Manjee</p>
              <p class="preview-lede">
                Every change in the sidebar applies instantly to the tokens
                below. Switching theme mode rebuilds the whole palette;
                manual token overrides win over the generator.
              </p>
            </Stack>
          </header>

          {/* Typography */}
          <section>
            <Stack gap="md">
              <h3 class="preview-section-title">Typography</h3>
              <GlassPanel size="lg">
                <Stack gap="lg">
                  <div>
                    <p class="type-meta">Display — Cormorant Garamond</p>
                    <p class="type-display">Prince Rehman</p>
                    <p class="type-display type-display--sub">P. R. Manjee</p>
                  </div>
                  <div>
                    <p class="type-meta">Body — Inter</p>
                    <p class="type-body">
                      Workplace modernization through AI adoption and digital
                      transformation. The body face has to read clearly at
                      long paragraph lengths without competing for attention.
                    </p>
                  </div>
                  <div>
                    <p class="type-meta">UI — Geist</p>
                    <p class="type-ui">Button labels, controls, and chrome use Geist.</p>
                  </div>
                  <div>
                    <p class="type-meta">Mono — JetBrains Mono</p>
                    <code class="type-mono">const palette = generate(mode, model, hue, contrast);</code>
                  </div>
                </Stack>
              </GlassPanel>
            </Stack>
          </section>

          {/* Color token grid */}
          <section>
            <Stack gap="md">
              <h3 class="preview-section-title">Color tokens</h3>
              <Grid min="240px" gap="sm">
                {previewColorTokens.map((t) => (
                  <div class="preview-swatch-row">
                    <div class="preview-swatch-chip" style={`background: var(${t.name});`} />
                    <div class="preview-swatch-meta">
                      <code class="preview-swatch-token">{t.name}</code>
                      <span class="preview-swatch-desc">{t.desc}</span>
                    </div>
                  </div>
                ))}
              </Grid>
            </Stack>
          </section>

          {/* Glass components */}
          <section>
            <Stack gap="md">
              <h3 class="preview-section-title">Glass components</h3>
              <Stack gap="md">
                <Stack direction="horizontal" gap="md" wrap>
                  <GlassButton variant="primary">Primary action</GlassButton>
                  <GlassButton variant="secondary">Secondary</GlassButton>
                  <GlassButton variant="emerald">Emerald</GlassButton>
                </Stack>
                <GlassPanel size="md">
                  <Stack gap="md">
                    <GlassField label="Email">
                      <GlassInput type="email" placeholder="you@example.com" />
                    </GlassField>
                    <GlassField label="Message">
                      <GlassTextarea rows={3} placeholder="Tell me about your project." />
                    </GlassField>
                  </Stack>
                </GlassPanel>
              </Stack>
            </Stack>
          </section>
        </Stack>
      </section>
    </div>
  </Container>
</BaseLayout>

<script>
  import {
    applyState,
    exportToFile,
    FACTORY_DEFAULT,
    importFromFile,
    loadFromLocalStorage,
    resetToFactory,
    saveToLocalStorage,
    setGenerator,
    setMode,
    setOverride,
    type EditorState,
  } from "../../lib/prism-editor-store";
  import type { ContrastLevel, MixingModel, ThemeMode } from "../../lib/prism-palette";

  // ─── State ────────────────────────────────────────────────────────────
  let state: EditorState = loadFromLocalStorage() ?? structuredClone(FACTORY_DEFAULT);

  // ─── Persistence (debounced) ──────────────────────────────────────────
  let saveTimer: number | undefined;
  function persist(): void {
    if (saveTimer !== undefined) clearTimeout(saveTimer);
    saveTimer = window.setTimeout(() => saveToLocalStorage(state), 300);
  }

  function commit(next: EditorState, opts: { skipPersist?: boolean } = {}): void {
    state = next;
    applyState(state);
    syncUI();
    if (!opts.skipPersist) persist();
  }

  function setStatus(msg: string): void {
    const el = document.querySelector<HTMLElement>("[data-editor-status]");
    if (!el) return;
    el.textContent = msg;
    // Reason: clear the message after a short visibility window so it
    // doesn't linger across unrelated actions.
    window.setTimeout(() => { if (el.textContent === msg) el.textContent = ""; }, 2400);
  }

  // ─── Color conversion (hex <-> rgb only; OKLCH stays as text) ─────────
  function hexToRgb(hex: string): { r: number; g: number; b: number } | null {
    const m = /^#?([0-9a-f]{6})$/i.exec(hex.trim());
    if (!m) return null;
    const n = parseInt(m[1], 16);
    return { r: (n >> 16) & 255, g: (n >> 8) & 255, b: n & 255 };
  }

  /** Best-effort conversion of an arbitrary CSS color value into a #rrggbb
   *  string the <input type="color"> picker can display. Uses an offscreen
   *  span + getComputedStyle so the browser does all the parsing for us. */
  function cssColorToHex(value: string): string {
    if (!value) return "#000000";
    const trim = value.trim();
    if (/^#[0-9a-f]{6}$/i.test(trim)) return trim.toLowerCase();
    if (typeof document === "undefined") return "#000000";
    const probe = document.createElement("span");
    probe.style.color = trim;
    document.body.appendChild(probe);
    const resolved = getComputedStyle(probe).color;
    probe.remove();
    const m = /^rgba?\(([^)]+)\)$/.exec(resolved);
    if (!m) return "#000000";
    const parts = m[1].split(",").map((s) => s.trim());
    const r = Math.max(0, Math.min(255, parseInt(parts[0] ?? "0", 10)));
    const g = Math.max(0, Math.min(255, parseInt(parts[1] ?? "0", 10)));
    const b = Math.max(0, Math.min(255, parseInt(parts[2] ?? "0", 10)));
    return "#" + [r, g, b].map((n) => n.toString(16).padStart(2, "0")).join("");
  }

  function computedToken(token: string): string {
    const root = document.documentElement;
    return getComputedStyle(root).getPropertyValue(token).trim();
  }

  // ─── UI sync ──────────────────────────────────────────────────────────
  function syncUI(): void {
    // Mode buttons
    document.querySelectorAll<HTMLButtonElement>("[data-editor-mode]").forEach((btn) => {
      const sel = btn.dataset.editorMode === state.mode;
      btn.setAttribute("aria-checked", sel ? "true" : "false");
      btn.classList.toggle("segment--selected", sel);
    });
    // Mixing model
    const modelSel = document.querySelector<HTMLSelectElement>("[data-editor-model]");
    if (modelSel) modelSel.value = state.generator.model;
    // Contrast
    document.querySelectorAll<HTMLButtonElement>("[data-editor-contrast]").forEach((btn) => {
      const sel = btn.dataset.editorContrast === state.generator.contrast;
      btn.setAttribute("aria-checked", sel ? "true" : "false");
      btn.classList.toggle("segment--selected", sel);
    });
    // Hue
    const hueSlider = document.querySelector<HTMLInputElement>("[data-editor-hue]");
    const hueNum = document.querySelector<HTMLInputElement>("[data-editor-hue-num]");
    if (hueSlider) hueSlider.value = String(state.generator.hue);
    if (hueNum) hueNum.value = String(state.generator.hue);
    // Effect sliders (read current computed value, fall back to override)
    syncEffect("--glass-blur", "px", "[data-effect-blur-display]");
    syncEffect("--glass-saturate", "%", "[data-effect-saturate-display]");
    syncEffect("--duration-base", "ms", "[data-effect-duration-display]");
    // Token color pickers: refresh visible swatch + hex from computed style.
    document.querySelectorAll<HTMLInputElement>("[data-editor-token-color]").forEach((el) => {
      const token = el.dataset.editorTokenColor!;
      const current = state.tokenOverrides[token] ?? computedToken(token);
      el.value = cssColorToHex(current);
      const row = document.querySelector<HTMLElement>(`[data-editor-token-row="${token}"]`);
      const preview = row?.querySelector<HTMLElement>(".token-preview");
      if (preview) preview.style.background = current;
      const overridden = token in state.tokenOverrides;
      row?.classList.toggle("token-row--overridden", overridden);
    });
  }

  function syncEffect(token: string, unit: string, displaySel: string): void {
    const input = document.querySelector<HTMLInputElement>(`[data-editor-effect="${token}"]`);
    const disp = document.querySelector<HTMLElement>(displaySel);
    if (!input) return;
    const value = state.tokenOverrides[token] ?? computedToken(token);
    const numMatch = /(-?\d+(?:\.\d+)?)/.exec(value);
    let n: number = NaN;
    if (numMatch) {
      n = parseFloat(numMatch[1]);
      if (unit === "ms" && /s$/.test(value) && !/ms$/.test(value)) n *= 1000;
    }
    if (Number.isFinite(n)) input.value = String(Math.round(n));
    if (disp) disp.textContent = Number.isFinite(n) ? `${Math.round(n)}${unit}` : value;
  }

  // ─── Wiring ───────────────────────────────────────────────────────────
  function bindMode(): void {
    document.querySelectorAll<HTMLButtonElement>("[data-editor-mode]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const mode = btn.dataset.editorMode as ThemeMode | undefined;
        if (!mode) return;
        commit(setMode(state, mode));
      });
    });
  }

  function bindGenerator(): void {
    const hueSlider = document.querySelector<HTMLInputElement>("[data-editor-hue]");
    const hueNum = document.querySelector<HTMLInputElement>("[data-editor-hue-num]");
    function applyHue(v: number): void {
      const hue = Math.max(0, Math.min(360, Math.round(v)));
      commit(setGenerator(state, { hue }));
    }
    hueSlider?.addEventListener("input", () => applyHue(Number(hueSlider.value)));
    hueNum?.addEventListener("change", () => applyHue(Number(hueNum.value)));

    const modelSel = document.querySelector<HTMLSelectElement>("[data-editor-model]");
    modelSel?.addEventListener("change", () => {
      commit(setGenerator(state, { model: modelSel.value as MixingModel }));
    });

    document.querySelectorAll<HTMLButtonElement>("[data-editor-contrast]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const contrast = btn.dataset.editorContrast as ContrastLevel | undefined;
        if (!contrast) return;
        commit(setGenerator(state, { contrast }));
      });
    });

    document.querySelector<HTMLButtonElement>("[data-editor-generate]")?.addEventListener("click", () => {
      // Reason: most controls already auto-apply; explicit Generate is a
      // user affordance that simply re-applies the current state.
      applyState(state);
      syncUI();
      setStatus("Palette regenerated");
    });
  }

  function bindQuickSwatches(): void {
    document.querySelectorAll<HTMLButtonElement>("[data-editor-quick-swatch]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const hueStr = btn.dataset.editorQuickHue;
        if (!hueStr) return;
        const hue = Math.round(Number(hueStr));
        if (!Number.isFinite(hue)) return;
        // Clear color overrides so the swatch's generated palette is visible
        // without manual picks fighting it.
        const cleared: EditorState = { ...state, tokenOverrides: {} };
        commit(setGenerator(cleared, { hue }));
        setStatus(`Applied swatch (hue ${hue}°)`);
      });
    });
  }

  function bindTokens(): void {
    document.querySelectorAll<HTMLInputElement>("[data-editor-token-color]").forEach((el) => {
      const token = el.dataset.editorTokenColor!;
      el.addEventListener("input", () => {
        commit(setOverride(state, token, el.value));
      });
    });
    document.querySelectorAll<HTMLButtonElement>("[data-editor-token-clear]").forEach((btn) => {
      const token = btn.dataset.editorTokenClear!;
      btn.addEventListener("click", () => {
        commit(setOverride(state, token, null));
      });
    });
    document.querySelectorAll<HTMLButtonElement>("[data-editor-token-oklch-toggle]").forEach((btn) => {
      const token = btn.dataset.editorTokenOklchToggle!;
      const fields = document.querySelector<HTMLElement>(`[data-editor-token-oklch-fields="${token}"]`);
      btn.addEventListener("click", () => {
        if (!fields) return;
        const open = !fields.hasAttribute("hidden");
        if (open) {
          fields.setAttribute("hidden", "");
          btn.setAttribute("aria-expanded", "false");
        } else {
          fields.removeAttribute("hidden");
          btn.setAttribute("aria-expanded", "true");
        }
      });
    });

    function bindOklch(token: string): void {
      const lEl = document.querySelector<HTMLInputElement>(`[data-editor-token-l="${token}"]`);
      const cEl = document.querySelector<HTMLInputElement>(`[data-editor-token-c="${token}"]`);
      const hEl = document.querySelector<HTMLInputElement>(`[data-editor-token-h="${token}"]`);
      function applyOklch(): void {
        const L = Number(lEl?.value);
        const C = Number(cEl?.value);
        const h = Number(hEl?.value);
        if (![L, C, h].every(Number.isFinite)) return;
        commit(setOverride(state, token, `oklch(${L} ${C} ${h})`));
      }
      lEl?.addEventListener("change", applyOklch);
      cEl?.addEventListener("change", applyOklch);
      hEl?.addEventListener("change", applyOklch);
    }
    document.querySelectorAll<HTMLElement>("[data-editor-token-oklch-fields]").forEach((el) => {
      bindOklch(el.dataset.editorTokenOklchFields!);
    });
  }

  function bindEffects(): void {
    document.querySelectorAll<HTMLInputElement>("[data-editor-effect]").forEach((el) => {
      const token = el.dataset.editorEffect!;
      const unit = el.dataset.effectUnit ?? "";
      el.addEventListener("input", () => {
        const value = `${el.value}${unit}`;
        commit(setOverride(state, token, value));
      });
    });
  }

  function bindPersistence(): void {
    document.querySelector<HTMLButtonElement>("[data-editor-reset]")?.addEventListener("click", () => {
      commit(resetToFactory(), { skipPersist: true });
      setStatus("Reset to factory defaults");
    });
    document.querySelector<HTMLButtonElement>("[data-editor-export]")?.addEventListener("click", () => {
      exportToFile(state);
      setStatus("Exported prism-overrides.json");
    });
    document.querySelector<HTMLButtonElement>("[data-editor-import]")?.addEventListener("click", async () => {
      try {
        const imported = await importFromFile();
        commit(imported);
        setStatus("Import applied");
      } catch (err) {
        setStatus(err instanceof Error ? err.message : "Import failed");
      }
    });
  }

  function bindMobileDrawer(): void {
    const toggle = document.querySelector<HTMLButtonElement>("[data-editor-mobile-toggle]");
    const sidebar = document.querySelector<HTMLElement>("[data-editor-sidebar]");
    if (!toggle || !sidebar) return;
    toggle.addEventListener("click", () => {
      const open = sidebar.classList.toggle("editor-sidebar--open");
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
    });
  }

  // ─── Optional integration: Agent C's <TokenUsage> ─────────────────────
  // Feature-detect at runtime WITHOUT a bundler-resolvable import. Astro
  // builds this script with Vite/Rollup, which will fail the build on any
  // unresolved static-string `import("…")` — so we can't reference Agent
  // C's component path directly even with /* @vite-ignore */ in a static
  // tree. Instead we check the site origin for a known global marker that
  // Agent C's component would install. If they install something else we
  // can teach the editor to read it via a window property; either way,
  // this file never imports the component, so the build stays clean.
  function maybeAttachTokenUsage(): void {
    // Reason: Agent C may register either a custom element (<token-usage>)
    // or a window-level helper. We probe both, and only light up the slot
    // hint if one of them is genuinely present in the runtime.
    const win = window as unknown as { __prismTokenUsage?: unknown };
    const hasCustomElement =
      typeof customElements !== "undefined" &&
      typeof customElements.get === "function" &&
      !!customElements.get("token-usage");
    const hasGlobalHelper = typeof win.__prismTokenUsage !== "undefined";
    if (!hasCustomElement && !hasGlobalHelper) return;
    document.querySelectorAll<HTMLElement>("[data-editor-token-usage]").forEach((slot) => {
      const token = slot.dataset.editorTokenUsage;
      if (!token) return;
      if (hasCustomElement) {
        // Lazily mount Agent C's element so it can fetch / render usage
        // data per token. Component author owns the internals.
        const el = document.createElement("token-usage");
        el.setAttribute("token", token);
        slot.replaceChildren(el);
      } else {
        slot.textContent = "(usage data available)";
      }
      slot.classList.add("token-usage-slot--active");
    });
  }

  // ─── Boot ─────────────────────────────────────────────────────────────
  function boot(): void {
    applyState(state);
    syncUI();
    bindMode();
    bindGenerator();
    bindQuickSwatches();
    bindTokens();
    bindEffects();
    bindPersistence();
    bindMobileDrawer();
    maybeAttachTokenUsage();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }
</script>

