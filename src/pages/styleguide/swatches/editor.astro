---
/**
 * Prism Swatch Editor — 4-slider playground for the generated palette.
 *
 * Route: /styleguide/swatches/editor
 *
 * Purpose: let the operator dial (hueA, hueB, intensityA, intensityB) and
 * see the same configuration rendered across all 9 permutations of
 *   {analogous, split-complementary, complementary}  (the 3 mixing models)
 *   × {light, dark, hybrid}                          (the 3 theme modes)
 * simultaneously, so a single drag of the hue slider visibly answers the
 * question "does this hue work in every mode?"
 *
 * The page does NOT mutate the global <html data-theme>. Each of the 9
 * tiles is a self-contained preview that scopes the generated CSS custom
 * properties to its own wrapper (via inline style="--bg-1: ...; ..."), so
 * the surrounding styleguide chrome keeps using the visitor's chosen theme
 * and the tiles never bleed into each other.
 *
 * State persistence + intensity math lives in
 *   src/lib/prism-swatch-editor-store.ts
 * Palette generation lives in
 *   src/lib/prism-palette.ts
 * Neither is modified by this page.
 *
 * Sibling page (untouched): src/pages/styleguide/swatches.astro
 */

import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/Container.astro";
import Stack from "../../../components/Stack.astro";
import { swatches } from "../../../data/prismSwatches";

const MODELS = ["analogous", "split-complementary", "complementary"] as const;
const MODES = ["light", "dark", "hybrid", "neomorphic"] as const;
const MODEL_LABELS: Record<(typeof MODELS)[number], string> = {
  analogous: "Analogous",
  "split-complementary": "Split-complementary",
  complementary: "Complementary",
};
const MODE_LABELS: Record<(typeof MODES)[number], string> = {
  light: "Light",
  dark: "Dark",
  hybrid: "Hybrid",
  neomorphic: "Neomorphic",
};

// Server-side serialization of swatches for the "Load swatch..." dropdown.
// Only id, name, type are needed by the dropdown; OKLCH lookups happen
// client-side against the imported `swatches` array.
const swatchOptions = swatches.map((s) => ({
  id: s.id,
  name: s.name,
  type: s.type,
}));
---

<BaseLayout
  title="Prism Swatch Editor — 4-slider playground"
  description="Drive (hueA, hueB, intensityA, intensityB) across all 9 model × mode permutations.">
  <Container size="2xl">
    <Stack gap="2xl">
      <Stack gap="sm" as="header">
        <p class="eyebrow">Prism · Phase 2 · editor</p>
        <h1 class="page-title">Swatch editor</h1>
        <p class="lede">
          Four sliders drive the generator across the full 3-model by
          3-mode matrix below. The tiles render in isolation, so the rest
          of the page keeps the theme you walked in with.
        </p>
      </Stack>

      <!-- ─── Sticky control bar ───────────────────────────────── -->
      <div class="control-bar" role="region" aria-label="Editor controls">
        <div class="sliders">
          <div class="slider-row">
            <label class="slider-label" for="hueA">Hue A</label>
            <input type="range" id="hueA" class="slider" min="0" max="360" step="1" value="263" data-control="hueA" />
            <input type="number" class="num" min="0" max="360" step="1" value="263" data-control="hueA-num" aria-label="Hue A value" />
            <span class="unit">deg</span>
          </div>
          <div class="slider-row">
            <label class="slider-label" for="hueB">Hue B</label>
            <input type="range" id="hueB" class="slider" min="0" max="360" step="1" value="152" data-control="hueB" />
            <input type="number" class="num" min="0" max="360" step="1" value="152" data-control="hueB-num" aria-label="Hue B value" />
            <span class="unit">deg</span>
          </div>
          <div class="slider-row">
            <label class="slider-label" for="intensityA">Intensity A</label>
            <input type="range" id="intensityA" class="slider" min="0" max="100" step="1" value="100" data-control="intensityA" />
            <input type="number" class="num" min="0" max="100" step="1" value="100" data-control="intensityA-num" aria-label="Intensity A value" />
            <span class="unit">%</span>
          </div>
          <div class="slider-row">
            <label class="slider-label" for="intensityB">Intensity B</label>
            <input type="range" id="intensityB" class="slider" min="0" max="100" step="1" value="100" data-control="intensityB" />
            <input type="number" class="num" min="0" max="100" step="1" value="100" data-control="intensityB-num" aria-label="Intensity B value" />
            <span class="unit">%</span>
          </div>
        </div>
        <div class="persistence">
          <label class="load-row">
            <span class="load-row-label">Load swatch</span>
            <select class="load-select" data-control="load-swatch">
              <option value="">— pick one —</option>
              {swatchOptions.map((o) => (
                <option value={o.id}>{o.name}{o.type === "palette" ? " (palette)" : ""}</option>
              ))}
            </select>
          </label>
          <div class="persistence-buttons">
            <button type="button" class="pbtn" data-action="reset">Reset to factory</button>
            <button type="button" class="pbtn" data-action="export">Export…</button>
            <button type="button" class="pbtn" data-action="import">Import…</button>
          </div>
        </div>
      </div>

      <!-- ─── 3×3 preview matrix ───────────────────────────────── -->
      <div class="matrix-wrap">
        <table class="matrix" aria-label="Mixing-model by theme-mode preview matrix">
          <thead>
            <tr>
              <th scope="col" class="corner" aria-hidden="true"></th>
              {MODES.map((mode) => (
                <th scope="col" class="col-header">{MODE_LABELS[mode]}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {MODELS.map((model) => (
              <tr>
                <th scope="row" class="row-header">{MODEL_LABELS[model]}</th>
                {MODES.map((mode) => (
                  <td class="tile-cell">
                    <div
                      class="tile"
                      data-tile
                      data-model={model}
                      data-mode={mode}
                      aria-label={`${MODEL_LABELS[model]} on ${MODE_LABELS[mode]}`}
                    >
                      <div class="tile-bg" data-tile-bg>
                        <div class="tile-panel" data-tile-panel>
                          <div class="tile-wordmark" data-tile-wordmark>Aa</div>
                          <div class="tile-chips">
                            <span class="tile-chip" data-tile-chip="base" aria-hidden="true"></span>
                            <span class="tile-chip" data-tile-chip="bright" aria-hidden="true"></span>
                            <span class="tile-chip" data-tile-chip="deep" aria-hidden="true"></span>
                          </div>
                          <div class="tile-text">
                            <p class="tile-text-primary" data-tile-text-primary>The quick brown fox</p>
                            <p class="tile-text-secondary" data-tile-text-secondary>jumps over the lazy dog.</p>
                          </div>
                        </div>
                      </div>
                      <div class="tile-foot">
                        <span class="tile-foot-label">contrast</span>
                        <span class="tile-foot-value" data-tile-contrast>—</span>
                      </div>
                    </div>
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- ─── Details panel: OKLCH per tile ─────────────────────── -->
      <section class="details" aria-label="OKLCH math details">
        <header class="details-header">
          <h2 class="details-title">Primary accents</h2>
          <p class="details-sub">OKLCH values produced for each of the 9 tiles' primary accent after intensity A is applied.</p>
        </header>
        <div class="details-grid">
          {MODELS.map((model) => MODES.map((mode) => (
            <div class="details-row" data-detail data-model={model} data-mode={mode}>
              <span class="details-row-key">{MODEL_LABELS[model]} · {MODE_LABELS[mode]}</span>
              <code class="details-row-value" data-detail-value>—</code>
            </div>
          )))}
        </div>
      </section>

      <p class="status" data-status aria-live="polite"></p>
    </Stack>
  </Container>
</BaseLayout>

<script>
  // ─── Client-side editor logic ───────────────────────────────────
  //
  // Imports the pure palette generator and the persistence helpers,
  // wires the four sliders to the 9 preview tiles, and keeps the
  // localStorage snapshot in sync (debounced).
  //
  // Generating 9 palettes on every input event is cheap (the generator
  // is O(1) math, no DOM), but we still debounce the slider input to
  // ~50 ms for smoothness and the localStorage write to ~300 ms to
  // avoid hammering storage during a drag.
  import { generatePalette } from "../../../lib/prism-palette";
  import type { MixingModel, ThemeMode } from "../../../lib/prism-palette";
  import {
    FACTORY_DEFAULT,
    type SwatchEditorState,
    loadFromLocalStorage,
    saveToLocalStorage,
    exportToFile,
    importFromFile,
    resetToFactory,
    applyIntensityToOklch,
  } from "../../../lib/prism-swatch-editor-store";
  import { swatches, isMono } from "../../../data/prismSwatches";

  const MODELS = ["analogous", "split-complementary", "complementary"] as const;
  const MODES = ["light", "dark", "hybrid", "neomorphic"] as const;
  // The CSS custom properties from a generated palette that we want to
  // promote onto each tile's wrapper. Limited to the ones the tile
  // actually paints (bg, glass, accents, brand, highlights, text)
  // because tiles never render full-page chrome.
  const TILE_VARS = [
    "--bg-1", "--bg-2", "--bg-3", "--bg-4",
    "--bg-overlay-1", "--bg-overlay-2",
    "--glass-bg", "--glass-bg-hover",
    "--glass-border", "--glass-border-strong",
    "--highlight-top", "--highlight-top-soft",
    "--highlight-bottom", "--highlight-bottom-soft",
    "--shadow-side",
    "--accent-royal", "--accent-royal-bright", "--accent-royal-deep",
    "--accent-emerald", "--accent-emerald-bright", "--accent-emerald-deep",
    "--brand-color", "--brand-glow",
  ] as const;

  // The two scoped text tokens each tile uses so legibility samples
  // automatically follow the mode's body-text colour. tokens.css owns
  // the cascade-level defaults; tiles override per mode below.
  const TEXT_TOKENS: Record<ThemeMode, { primary: string; secondary: string }> = {
    light: {
      primary: "oklch(0.220 0.022 270)",
      secondary: "oklch(0.355 0.022 270)",
    },
    dark: {
      primary: "oklch(1 0 0 / 0.96)",
      secondary: "oklch(1 0 0 / 0.86)",
    },
    hybrid: {
      primary: "oklch(0.975 0.005 250)",
      secondary: "oklch(0.890 0.010 250)",
    },
    system: {
      primary: "oklch(1 0 0 / 0.96)",
      secondary: "oklch(1 0 0 / 0.86)",
    },
    neomorphic: {
      primary: "oklch(0.32 0.03 75)",
      secondary: "oklch(0.45 0.06 75)",
    },
  };

  // ─── State + DOM lookup ──────────────────────────────────────
  let state: SwatchEditorState = loadFromLocalStorage() ?? { ...FACTORY_DEFAULT };

  const slider = (name: string) =>
    document.querySelector<HTMLInputElement>(`[data-control="${name}"]`);
  const statusEl = document.querySelector<HTMLElement>("[data-status]");

  function setStatus(msg: string, kind: "ok" | "err" | "" = ""): void {
    if (!statusEl) return;
    statusEl.textContent = msg;
    statusEl.dataset.kind = kind;
  }

  // ─── OKLCH parsing for tile-local math ───────────────────────
  function parseOklch(value: string): { l: number; c: number; h: number; a: number } | null {
    const m = value.match(
      /oklch\(\s*([\d.]+)\s+([\d.]+)\s+([\d.]+)(?:\s*\/\s*([\d.]+))?\s*\)/i,
    );
    if (!m) return null;
    return {
      l: Number(m[1]),
      c: Number(m[2]),
      h: Number(m[3]),
      a: m[4] !== undefined ? Number(m[4]) : 1,
    };
  }

  // WCAG contrast ratio between two OKLCH strings. Mirrors the formula
  // used in prism-palette.ts so this page is self-sufficient (the
  // generator doesn't expose its sRGB conversion).
  function oklchToSrgb(L: number, C: number, hDeg: number): { r: number; g: number; b: number } {
    const hRad = (hDeg * Math.PI) / 180;
    const a = C * Math.cos(hRad);
    const b = C * Math.sin(hRad);
    const l_ = L + 0.3963377774 * a + 0.2158037573 * b;
    const m_ = L - 0.1055613458 * a - 0.0638541728 * b;
    const s_ = L - 0.0894841775 * a - 1.291485548 * b;
    const ll = l_ * l_ * l_;
    const mm = m_ * m_ * m_;
    const ss = s_ * s_ * s_;
    const rLin = 4.0767416621 * ll - 3.3077115913 * mm + 0.2309699292 * ss;
    const gLin = -1.2684380046 * ll + 2.6097574011 * mm - 0.3413193965 * ss;
    const bLin = -0.0041960863 * ll - 0.7034186147 * mm + 1.707614701 * ss;
    const enc = (x: number) => {
      const c = x < 0 ? 0 : x > 1 ? 1 : x;
      return c <= 0.0031308 ? 12.92 * c : 1.055 * Math.pow(c, 1 / 2.4) - 0.055;
    };
    return { r: enc(rLin), g: enc(gLin), b: enc(bLin) };
  }

  function relLum(rgb: { r: number; g: number; b: number }): number {
    const lin = (x: number) => {
      const c = x < 0 ? 0 : x > 1 ? 1 : x;
      return c <= 0.04045 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
    };
    return 0.2126 * lin(rgb.r) + 0.7152 * lin(rgb.g) + 0.0722 * lin(rgb.b);
  }

  function contrast(aStr: string, bStr: string): number | null {
    const a = parseOklch(aStr);
    const b = parseOklch(bStr);
    if (!a || !b) return null;
    const la = relLum(oklchToSrgb(a.l, a.c, a.h));
    const lb = relLum(oklchToSrgb(b.l, b.c, b.h));
    const Lmax = Math.max(la, lb);
    const Lmin = Math.min(la, lb);
    return (Lmax + 0.05) / (Lmin + 0.05);
  }

  // ─── Render: paint the 9 tiles and the details rows ──────────
  function render(): void {
    for (const model of MODELS) {
      for (const mode of MODES) {
        const tile = document.querySelector<HTMLElement>(
          `[data-tile][data-model="${model}"][data-mode="${mode}"]`,
        );
        if (!tile) continue;

        // Primary triad: generator with hueA + intensityA chroma scale.
        const primaryPalette = generatePalette({
          mode: mode as ThemeMode,
          model: model as MixingModel,
          hue: state.hueA,
          contrast: "AA",
        });
        // Secondary triad: generator with hueB; we take its --accent-royal
        // family (the primary it produces) and remap onto the emerald
        // CSS variables. This realises the spec's "Hue B is the alt-accent
        // axis" rule without leaning on the secondary-hue rotation that
        // the model param would otherwise apply.
        const secondaryPalette = generatePalette({
          mode: mode as ThemeMode,
          model: model as MixingModel,
          hue: state.hueB,
          contrast: "AA",
        });

        // Apply intensity multipliers to the accent chroma.
        const royal = applyIntensityToOklch(primaryPalette["--accent-royal"], state.intensityA)!;
        const royalBright = applyIntensityToOklch(primaryPalette["--accent-royal-bright"], state.intensityA)!;
        const royalDeep = applyIntensityToOklch(primaryPalette["--accent-royal-deep"], state.intensityA)!;
        const emerald = applyIntensityToOklch(secondaryPalette["--accent-royal"], state.intensityB)!;
        const emeraldBright = applyIntensityToOklch(secondaryPalette["--accent-royal-bright"], state.intensityB)!;
        const emeraldDeep = applyIntensityToOklch(secondaryPalette["--accent-royal-deep"], state.intensityB)!;

        // Build the inline style payload. Iterating TILE_VARS keeps the
        // tile self-contained and overwrites any leftover values from a
        // previous render.
        const merged: Record<string, string | undefined> = {
          ...primaryPalette,
          "--accent-royal": royal,
          "--accent-royal-bright": royalBright,
          "--accent-royal-deep": royalDeep,
          "--accent-emerald": emerald,
          "--accent-emerald-bright": emeraldBright,
          "--accent-emerald-deep": emeraldDeep,
        };
        const styleParts: string[] = [];
        for (const v of TILE_VARS) {
          const val = merged[v];
          if (val !== undefined) styleParts.push(`${v}: ${val}`);
        }
        // Scoped text tokens so tile copy is legible against the tile bg
        // regardless of the visitor's outer theme.
        styleParts.push(`--color-fg-primary: ${TEXT_TOKENS[mode as ThemeMode].primary}`);
        styleParts.push(`--color-fg-secondary: ${TEXT_TOKENS[mode as ThemeMode].secondary}`);
        tile.setAttribute("style", styleParts.join("; "));

        // Paint the three accent chips inline (they read --accent-royal*).
        const chipBase = tile.querySelector<HTMLElement>('[data-tile-chip="base"]');
        const chipBright = tile.querySelector<HTMLElement>('[data-tile-chip="bright"]');
        const chipDeep = tile.querySelector<HTMLElement>('[data-tile-chip="deep"]');
        if (chipBase) chipBase.style.background = royal;
        if (chipBright) chipBright.style.background = royalBright;
        if (chipDeep) chipDeep.style.background = royalDeep;

        // Contrast: primary accent vs. the tile's bg-2 (the dominant
        // mid stop, which is closer to what the chip actually sits on
        // than bg-1 due to the gradient blend).
        const surface = merged["--bg-2"] ?? merged["--bg-1"] ?? "oklch(0.2 0 0)";
        const ratio = contrast(royal, surface);
        const ratioEl = tile.querySelector<HTMLElement>("[data-tile-contrast]");
        if (ratioEl) {
          if (ratio === null) {
            ratioEl.textContent = "n/a";
            ratioEl.dataset.tier = "";
          } else {
            ratioEl.textContent = `${ratio.toFixed(2)}:1`;
            ratioEl.dataset.tier =
              ratio >= 7 ? "aaa" : ratio >= 4.5 ? "aa" : ratio >= 3 ? "ui" : "fail";
          }
        }

        // Details row.
        const detail = document.querySelector<HTMLElement>(
          `[data-detail][data-model="${model}"][data-mode="${mode}"] [data-detail-value]`,
        );
        if (detail) detail.textContent = royal;
      }
    }
  }

  // ─── Debounced persistence ───────────────────────────────────
  let saveTimer: number | undefined;
  function scheduleSave(): void {
    if (saveTimer !== undefined) window.clearTimeout(saveTimer);
    saveTimer = window.setTimeout(() => saveToLocalStorage(state), 300);
  }

  // ─── Debounced render ────────────────────────────────────────
  let renderTimer: number | undefined;
  function scheduleRender(): void {
    if (renderTimer !== undefined) window.clearTimeout(renderTimer);
    renderTimer = window.setTimeout(() => render(), 50);
  }

  // ─── Wire control inputs ─────────────────────────────────────
  function bindControl(key: "hueA" | "hueB" | "intensityA" | "intensityB"): void {
    const range = slider(key);
    const num = slider(`${key}-num`);
    if (!range || !num) return;

    const apply = (raw: string) => {
      const max = key.startsWith("hue") ? 360 : 100;
      let n = Number(raw);
      if (!Number.isFinite(n)) n = state[key];
      if (n < 0) n = 0;
      if (n > max) n = max;
      state[key] = n;
      range.value = String(n);
      num.value = String(n);
      scheduleRender();
      scheduleSave();
    };

    range.addEventListener("input", (e) => apply((e.target as HTMLInputElement).value));
    num.addEventListener("input", (e) => apply((e.target as HTMLInputElement).value));
  }

  function setAll(s: SwatchEditorState): void {
    state = { ...s };
    for (const key of ["hueA", "hueB", "intensityA", "intensityB"] as const) {
      const range = slider(key);
      const num = slider(`${key}-num`);
      if (range) range.value = String(state[key]);
      if (num) num.value = String(state[key]);
    }
    render();
    scheduleSave();
  }

  bindControl("hueA");
  bindControl("hueB");
  bindControl("intensityA");
  bindControl("intensityB");

  // ─── Persistence buttons ─────────────────────────────────────
  document.querySelector<HTMLButtonElement>('[data-action="reset"]')?.addEventListener("click", () => {
    setAll(resetToFactory());
    setStatus("Reset to factory defaults.", "ok");
  });

  document.querySelector<HTMLButtonElement>('[data-action="export"]')?.addEventListener("click", () => {
    exportToFile(state);
    setStatus("Exported snapshot.", "ok");
  });

  document.querySelector<HTMLButtonElement>('[data-action="import"]')?.addEventListener("click", async () => {
    try {
      const imported = await importFromFile();
      setAll(imported);
      setStatus("Imported snapshot.", "ok");
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      // Don't surface user cancellation as a scary error.
      if (/cancelled/i.test(msg)) {
        setStatus("");
      } else {
        setStatus(`Import failed: ${msg}`, "err");
      }
    }
  });

  // ─── Swatch dropdown ─────────────────────────────────────────
  // Mono swatches set Hue A and leave Hue B alone (per spec). Palettes
  // pick the two most-chromatic distinct hues from the palette's flat
  // colour list, dropping near-greys (chroma < 0.04) so the two slots
  // get real accent hues.
  document.querySelector<HTMLSelectElement>('[data-control="load-swatch"]')?.addEventListener("change", (e) => {
    const id = (e.target as HTMLSelectElement).value;
    if (!id) return;
    const s = swatches.find((sw) => sw.id === id);
    if (!s) return;
    if (isMono(s)) {
      state.hueA = ((s.oklch.h % 360) + 360) % 360;
    } else {
      const allColors: { c: number; h: number }[] = [];
      for (const g of s.groups) {
        for (const col of g.colors) {
          const m = col.value.match(
            /oklch\(\s*([\d.]+)\s+([\d.]+)\s+([\d.]+)/i,
          );
          if (m) allColors.push({ c: Number(m[2]), h: Number(m[3]) });
        }
      }
      const chroma = allColors.filter((c) => c.c >= 0.04);
      // Sort by chroma descending so the two most saturated hues win.
      chroma.sort((a, b) => b.c - a.c);
      const hues: number[] = [];
      for (const c of chroma) {
        const h = ((c.h % 360) + 360) % 360;
        // Skip a hue if it sits within 20deg of one we already picked.
        if (hues.some((existing) => {
          const d = Math.abs(existing - h);
          return Math.min(d, 360 - d) < 20;
        })) continue;
        hues.push(h);
        if (hues.length >= 2) break;
      }
      if (hues[0] !== undefined) state.hueA = hues[0];
      if (hues[1] !== undefined) state.hueB = hues[1];
    }
    setAll(state);
    setStatus(`Loaded "${s.name}".`, "ok");
  });

  // ─── Initial paint ───────────────────────────────────────────
  setAll(state);
</script>

<style>
  .eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-fg-muted);
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 4vw + 1rem, var(--text-4xl));
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--color-fg-primary);
  }
  .lede {
    max-width: 720px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-fg-secondary);
  }

  /* ─── Control bar ────────────────────────────────────────── */
  .control-bar {
    position: sticky;
    top: 80px;
    z-index: 10;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.7fr);
    gap: var(--space-lg);
    padding: 16px 20px;
    background: var(--glass-bg-hover);
    border: 1px solid var(--glass-border-strong);
    border-radius: var(--radius-lg);
