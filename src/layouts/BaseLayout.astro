---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import MobileNav from "../components/MobileNav.astro";
import Footer from "../components/Footer.astro";
import PrismPanel from "../components/PrismPanel.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "P. R. Manjee. Senior Technology Consultant. Workplace Modernization through AI Adoption and Digital Transformation for SMB, Mid-Market, and Enterprise.",
  ogImage = "/social-card.png",
} = Astro.props;

const ogImageUrl = new URL(ogImage, Astro.url).href;
const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph (LinkedIn, Slack, Discord, iMessage, etc) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="P. R. Manjee — Senior Technology Consultant" />
    <meta property="og:site_name" content="P. R. Manjee" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="P. R. Manjee — Senior Technology Consultant" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0a0e27" />

    <link rel="canonical" href={canonicalUrl} />

    {/*
      Prism theme bootstrap: runs synchronously before any paint to apply
      the user's stored theme (or default to dark) on the <html> element.
      Lives inline in <head> with is:inline so Astro does not defer it.
      Keep this script minimal and side-effect-free beyond setting the
      data-theme attribute, since it blocks the first paint.
    */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("prism-theme");
          var valid = ["dark", "light", "hybrid", "system", "neomorphic"];
          var theme = stored && valid.indexOf(stored) !== -1 ? stored : "dark";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>

    {/*
      Google Fonts:
        Cormorant Garamond — display, brand name, section headings
        Inter — body text
        Geist — UI labels and button text
        JetBrains Mono — code and technical text
    */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@300..900&family=Geist:wght@400..700&family=JetBrains+Mono:wght@400..600&display=swap"
    />

    <!-- Structured data for search engines (Person schema) -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "P. R. Manjee",
      "alternateName": "Prince Rehman Manjee",
      "jobTitle": "Senior Technology Consultant",
      "description": description,
      "url": "https://princerehman.com",
      "sameAs": [
        "https://www.linkedin.com/in/princemanjee/",
        "https://github.com/princemanjee"
      ],
      "knowsAbout": [
        "AI Adoption",
        "Digital Transformation",
        "Workplace Modernization",
        "Cloud Computing",
        "Solutions Architecture"
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Chicago",
        "addressRegion": "IL",
        "addressCountry": "US"
      }
    })} />

    <title>{title}</title>
  </head>
  <body>
    {/*
      Global SVG filters used by brand identity components.
      Defined once here so all components can reference them via filter URL.
    */}
    <svg style="position: absolute; width: 0; height: 0; pointer-events: none;" aria-hidden="true">
      <defs>
        {/*
          prism-polished: smooth rounded specular bevel for the wordmark.
          feGaussianBlur on alpha creates a rounded height map.
          feSpecularLighting with point light produces a real specular highlight.
        */}
        <filter id="prism-polished" x="-30%" y="-30%" width="160%" height="160%">
          <feGaussianBlur in="SourceAlpha" stdDeviation="2.5" result="blur" />
          <feSpecularLighting
            in="blur"
            surfaceScale="5"
            specularConstant="1.6"
            specularExponent="30"
            lighting-color="#ffffff"
            result="specular"
          >
            <fePointLight x="-100" y="-200" z="350" />
          </feSpecularLighting>
          <feComposite in="specular" in2="SourceAlpha" operator="in" result="masked" />
          <feMerge>
            <feMergeNode in="SourceGraphic" />
            <feMergeNode in="masked" />
          </feMerge>
        </filter>

        {/*
          prism-polished-small: variant tuned for small wordmark renderings
          (BrandName xs at footer / mobile-nav scale).

          Aggressive subtlety relative to prism-polished:
          - lighting-color is a pale steel-blue (#d8e4f4) instead of pure
            white, so the specular highlight integrates with the royal-blue
            brand color rather than washing it out. At large size the white
            speculars cover only the top edges; at small size pure white
            would cover most of each glyph and turn the wordmark pale.
          - surfaceScale 2 and specularConstant 0.6 give a much gentler
            bevel that suggests gloss without flashing.
          - specularExponent 50 tightens the highlight area.
          - Light centered above (x=0 y=-40 z=320) so any highlight that
            does show lands mid-glyph, not on the upper-left edge.
        */}
        <filter id="prism-polished-small" x="-30%" y="-30%" width="160%" height="160%">
          <feGaussianBlur in="SourceAlpha" stdDeviation="1.2" result="blur" />
          <feSpecularLighting
            in="blur"
            surfaceScale="2.5"
            specularConstant="0.85"
            specularExponent="48"
            lighting-color="#d8e4f4"
            result="specular"
          >
            <fePointLight x="0" y="-40" z="320" />
          </feSpecularLighting>
          <feComposite in="specular" in2="SourceAlpha" operator="in" result="masked" />
          <feMerge>
            <feMergeNode in="SourceGraphic" />
            <feMergeNode in="masked" />
          </feMerge>
        </filter>

        {/*
          prism-polished-small-bright: the dark-surface variant of the
          small filter. Pure white lighting and stronger specular so the
          polished bevel reads clearly on dark backgrounds (mobile nav
          panel, dark/hybrid theme footers). The light-surface variant
          above uses tinted lighting to avoid washing the deeper royal
          brand color on sand/off-white surfaces; this variant assumes
          the brand color is the pale luminous form used on dark themes.
        */}
        <filter id="prism-polished-small-bright" x="-30%" y="-30%" width="160%" height="160%">
          <feGaussianBlur in="SourceAlpha" stdDeviation="1.4" result="blur" />
          <feSpecularLighting
            in="blur"
            surfaceScale="3.5"
            specularConstant="1.4"
            specularExponent="32"
            lighting-color="#ffffff"
            result="specular"
          >
            <fePointLight x="-40" y="-80" z="300" />
          </feSpecularLighting>
          <feComposite in="specular" in2="SourceAlpha" operator="in" result="masked" />
          <feMerge>
            <feMergeNode in="SourceGraphic" />
            <feMergeNode in="masked" />
          </feMerge>
        </filter>

        {/*
          prism-embossed-pronounced: stronger 3D raised-relief effect for
          the brand mark chevron inside the orb. Doubled surface scale
          versus prism-polished, plus a secondary cool fill light for
          dimensional form. Reads as substantively raised material.
        */}
        <filter id="prism-embossed-pronounced" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur in="SourceAlpha" stdDeviation="2" result="blur" />
          <feSpecularLighting
            in="blur"
            surfaceScale="12"
            specularConstant="2.5"
            specularExponent="20"
            lighting-color="#ffffff"
            result="specKey"
          >
            <fePointLight x="-60" y="-150" z="220" />
          </feSpecularLighting>
          <feComposite in="specKey" in2="SourceAlpha" operator="in" result="keyMasked" />
          <feSpecularLighting
            in="blur"
            surfaceScale="8"
            specularConstant="0.9"
            specularExponent="30"
            lighting-color="#b8c8e0"
            result="specFill"
          >
            <fePointLight x="120" y="200" z="160" />
          </feSpecularLighting>
          <feComposite in="specFill" in2="SourceAlpha" operator="in" result="fillMasked" />
          <feMerge>
            <feMergeNode in="SourceGraphic" />
            <feMergeNode in="fillMasked" />
            <feMergeNode in="keyMasked" />
          </feMerge>
        </filter>
      </defs>
    </svg>

    <Nav />
    <MobileNav />

    <main>
      <slot />
    </main>

    <Footer />

    <PrismPanel />
  </body>
</html>
