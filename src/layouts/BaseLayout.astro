---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "P. R. Manjee. Senior Technology Consultant. AI Adoption, Digital Transformation, MIT Sloan.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.href} />

    {/*
      Google Fonts:
        Cormorant Garamond — display, brand name, section headings
        Inter — body text
        Geist — UI labels and button text
        JetBrains Mono — code and technical text
    */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@300..900&family=Geist:wght@400..700&family=JetBrains+Mono:wght@400..600&display=swap"
    />

    <title>{title}</title>
  </head>
  <body>
    {/*
      Global SVG filter for the polished glass brand-name treatment.
      feGaussianBlur on alpha creates a rounded height map.
      feSpecularLighting with point light produces a real specular highlight.
      The result is smooth rounded bevels, not layer-striated text-shadows.
    */}
    <svg style="position: absolute; width: 0; height: 0; pointer-events: none;" aria-hidden="true">
      <defs>
        <filter id="prism-polished" x="-30%" y="-30%" width="160%" height="160%">
          <feGaussianBlur in="SourceAlpha" stdDeviation="2.5" result="blur" />
          <feSpecularLighting
            in="blur"
            surfaceScale="5"
            specularConstant="1.6"
            specularExponent="30"
            lighting-color="#ffffff"
            result="specular"
          >
            <fePointLight x="-100" y="-200" z="350" />
          </feSpecularLighting>
          <feComposite in="specular" in2="SourceAlpha" operator="in" result="masked" />
          <feMerge>
            <feMergeNode in="SourceGraphic" />
            <feMergeNode in="masked" />
          </feMerge>
        </filter>
      </defs>
    </svg>

    <main>
      <slot />
    </main>
  </body>
</html>
