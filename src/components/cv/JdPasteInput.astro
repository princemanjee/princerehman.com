---
/**
 * JdPasteInput — JD-paste box rendered inside the standard glass surface.
 *
 * REFACTOR: surface is now a <GlassPanel>; the textarea uses
 * <GlassTextarea> + <GlassField>; submit is a <GlassButton variant="primary">;
 * archive-fallback button is a secondary GlassButton. All bespoke
 * .jd-paste__* surface styles are gone — only the result-injection
 * markup keeps a few line-item styles for the live-tailoring output.
 */

import GlassPanel from "../GlassPanel.astro";
import GlassButton from "../GlassButton.astro";
import GlassField from "../GlassField.astro";
import GlassTextarea from "../GlassTextarea.astro";
import Stack from "../Stack.astro";

interface Props {
  initialAudience?: string;
}

const { initialAudience = "default" } = Astro.props;
---

<section
  class="jd-paste"
  aria-labelledby="jd-paste-heading"
  data-jd-paste
  data-initial-audience={initialAudience}>
  <GlassPanel size="lg">
    <Stack gap="md">
      <Stack gap="2xs">
        <h2 id="jd-paste-heading" class="jd-paste__heading">
          Tailor for a specific JD
        </h2>
        <p class="jd-paste__hint">
          Paste a job description and the resume reorders itself around it. Your text never leaves the gateway.
        </p>
      </Stack>

      <form class="jd-paste__form" data-jd-form>
        <Stack gap="sm">
          <GlassField label="Job description" htmlFor="jd-paste-textarea">
            <GlassTextarea
              name="jdText"
              id="jd-paste-textarea"
              rows={6}
              placeholder="Paste the JD here..."
              required
              class="jd-paste-textarea"
            />
          </GlassField>

          <Stack direction="horizontal" gap="md" align="center" wrap>
            <GlassButton variant="primary" size="sm" type="submit">
              <span data-jd-submit-inner>Tailor for this JD</span>
            </GlassButton>
            <span
              class="jd-paste__status"
              role="status"
              aria-live="polite"
              data-jd-status></span>
          </Stack>
        </Stack>
      </form>

      <div class="jd-paste__output" data-jd-output hidden></div>

      <div class="jd-paste__fallback" data-jd-fallback hidden>
        <Stack direction="horizontal" gap="sm" align="center" wrap>
          <p class="jd-paste__fallback-text" data-jd-fallback-text></p>
          <GlassButton variant="secondary" size="sm">
            <span data-jd-fallback-button>Use closest archive match instead</span>
          </GlassButton>
        </Stack>
      </div>
    </Stack>
  </GlassPanel>
</section>

<style>
  .jd-paste__heading { margin: 0; font-family: var(--font-display); font-weight: 600; font-size: var(--text-xl); color: var(--color-fg-primary); }
  .jd-paste__hint { margin: 0; font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-fg-tertiary); max-width: 72ch; }
  .jd-paste__form { display: contents; }
  .jd-paste__status { font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-fg-tertiary); }
  .jd-paste__output {
    display: flex; flex-direction: column; gap: var(--space-sm);
    padding: var(--space-md); border: 1px solid var(--glass-border);
    border-radius: var(--radius-md); background: var(--glass-bg-hover);
  }
  .jd-paste__output :global(.jd-paste__meta) { font-family: var(--font-ui); font-size: var(--text-xs); color: var(--color-fg-muted); text-transform: uppercase; letter-spacing: var(--tracking-wide); }
  .jd-paste__output :global(.jd-paste__summary) { margin: 0; max-width: 72ch; font-family: var(--font-body); line-height: var(--leading-relaxed); color: var(--color-fg-secondary); }
  .jd-paste__output :global(.jd-paste__role-bullets) { margin: var(--space-2xs) 0 0; padding-left: var(--space-lg); font-family: var(--font-body); line-height: var(--leading-relaxed); color: var(--color-fg-secondary); }
  .jd-paste__output :global(.jd-paste__role-id) { font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 600; color: var(--color-fg-muted); text-transform: uppercase; letter-spacing: var(--tracking-wide); }
  .jd-paste__fallback { padding: var(--space-sm) var(--space-md); border: 1px dashed var(--glass-border-strong); border-radius: var(--radius-md); }
  .jd-paste__fallback-text { margin: 0; font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-fg-secondary); }
</style>

<script>
  /*
   * Progressive-enhancement form. Identical behaviour to the previous
   * version - dynamic-import gateway and archive matcher modules so the
   * critical /cv bundle stays small.
   */
  const root = document.querySelector<HTMLElement>("[data-jd-paste]");
  if (root) {
    const form = root.querySelector<HTMLFormElement>("[data-jd-form]");
    const textarea = root.querySelector<HTMLTextAreaElement>("textarea");
    const submitInner = root.querySelector<HTMLElement>("[data-jd-submit-inner]");
    const submitButton = submitInner?.closest<HTMLButtonElement>("button");
    const status = root.querySelector<HTMLElement>("[data-jd-status]");
    const output = root.querySelector<HTMLElement>("[data-jd-output]");
    const fallback = root.querySelector<HTMLElement>("[data-jd-fallback]");
    const fallbackText = root.querySelector<HTMLElement>("[data-jd-fallback-text]");
    const fallbackButton = root.querySelector<HTMLElement>("[data-jd-fallback-button]");
    const fallbackButtonEl = fallbackButton?.closest<HTMLButtonElement>("button");

    let currentController: AbortController | null = null;

    function getAudience(): string {
      const switcher = document.querySelector<HTMLElement>("[data-audience-switcher]");
      const live = switcher?.dataset.current;
      if (live && live.length > 0) return live;
      return root!.dataset.initialAudience ?? "default";
    }

    function setBusy(busy: boolean, message?: string) {
      if (submitButton) submitButton.disabled = busy;
      if (textarea) textarea.disabled = busy;
      if (status) status.textContent = message ?? "";
    }

    function showFallback(message: string) {
      if (fallback && fallbackText) {
        fallbackText.textContent = message;
        fallback.hidden = false;
      }
    }
    function hideFallback() { if (fallback) fallback.hidden = true; }

    function renderResult(payload: {
      tailoredSummary: string;
      tailoredRoles: Array<{ roleId: string; bullets: string[] }>;
      model: string;
      cached: boolean;
      elapsedMs: number;
    }, sourceLabel: string) {
      if (!output) return;
      output.hidden = false;
      const bulletsHtml = payload.tailoredRoles
        .map((r) => {
          const items = r.bullets.map((b) => `<li>${escapeHtml(b)}</li>`).join("");
          return `
            <div class="jd-paste__role">
              <div class="jd-paste__role-id">${escapeHtml(r.roleId)}</div>
              <ul class="jd-paste__role-bullets">${items}</ul>
            </div>`;
        })
        .join("");
      output.innerHTML = `
        <div class="jd-paste__meta">
          ${escapeHtml(sourceLabel)} ${payload.cached ? " (cached)" : ""}
          ${payload.model ? ` via ${escapeHtml(payload.model)}` : ""}
          ${payload.elapsedMs ? ` in ${payload.elapsedMs}ms` : ""}
        </div>
        <h3 class="jd-paste__output-heading">Tailored summary</h3>
        <p class="jd-paste__summary">${escapeHtml(payload.tailoredSummary)}</p>
        ${bulletsHtml ? `<h3 class="jd-paste__output-heading">Tailored bullets</h3>${bulletsHtml}` : ""}
      `;
    }

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, "&amp;").replace(/</g, "&lt;")
        .replace(/>/g, "&gt;").replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    async function runArchiveFallback(audience: string, jdText: string) {
      setBusy(true, "Looking for the closest archive match...");
      try {
        const mod: any = await import(
          /* @vite-ignore */ "../../lib/cv-archive-match.ts"
        ).catch(() => null);
        if (!mod || typeof mod.matchArchive !== "function") {
          showFallback("Archive matcher is not available yet. Please try again later.");
          setBusy(false, "");
          return;
        }
        const archive = mod.ARCHIVE ?? mod.default ?? [];
        const matches = await mod.matchArchive(audience, jdText, archive, 1);
        const top = matches?.[0];
        if (!top) {
          showFallback("No archive match found for this audience.");
          setBusy(false, "");
          return;
        }
        renderResult(
          {
            tailoredSummary: top.summary ?? "(no summary in archive entry)",
            tailoredRoles: Array.isArray(top.roles) ? top.roles : [],
            model: "archive-match",
            cached: false,
            elapsedMs: 0,
          },
          "Showing the closest archive match",
        );
        hideFallback();
        setBusy(false, "");
      } catch (err) {
        showFallback(
          `Archive match failed: ${(err as Error).message ?? "unknown error"}`,
        );
        setBusy(false, "");
      }
    }

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      hideFallback();

      const jdText = textarea?.value?.trim() ?? "";
      if (!jdText) {
        setBusy(false, "Paste a JD first.");
        return;
      }

      currentController?.abort();
      currentController = new AbortController();
      setBusy(true, "Tailoring against your JD...");

      try {
        const mod = await import("../../lib/cv-claude-fallback");
        const audience = getAudience();
        const payload = await mod.callTailorGateway(
          { audience, jdText, archiveContext: "" },
          { signal: currentController.signal },
        );
        renderResult(payload, "Tailored live");
        setBusy(false, "");
      } catch (err) {
        if ((err as Error).name === "AbortError") {
          setBusy(false, "");
          return;
        }
        const status = (err as { status?: number }).status;
        if (status === 429) {
          showFallback(
            "You have hit the live-tailoring rate limit. You can still use the closest archive match.",
          );
        } else if (status === 502) {
          showFallback(
            "Live tailoring is temporarily unreachable. The closest archive match is available below.",
          );
        } else {
          showFallback(
            `Live tailoring failed (${(err as Error).message ?? "unknown"}). You can still try the archive match.`,
          );
        }
        setBusy(false, "");
      }
    });

    fallbackButtonEl?.addEventListener("click", (e) => {
      e.preventDefault();
      const jdText = textarea?.value?.trim() ?? "";
      void runArchiveFallback(getAudience(), jdText);
    });
  }
</script>
