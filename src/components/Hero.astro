---
import BrandMark from "./BrandMark.astro";
import BrandName from "./BrandName.astro";
import GlassButton from "./GlassButton.astro";
import GlassPanel from "./GlassPanel.astro";
---

<GlassPanel size="xl" class="hero">
  <div class="hero-lockup">
    <BrandMark size="xl" ariaLabel="P. R. Manjee" />
    <BrandName variant="full" size="xl" as="h1" />
  </div>

  <p class="hero-tagline">
    Senior Technology Consultant · Workplace Modernization through AI Adoption and Digital Transformation
  </p>

  <p class="hero-description">
    SMB, mid-market, and enterprise organizations call me when they need workplace modernization
    done right the first time. Thirty years of executing through AI adoption and digital
    transformation, building systems that stick, from electrons to executive strategy.
  </p>

  <div class="hero-actions">
    <GlassButton href="#work" variant="primary" size="md">
      View Selected Work
    </GlassButton>
    <GlassButton href="mailto:princemanjee@gmail.com" variant="secondary" size="md">
      Get in Touch
    </GlassButton>
  </div>

  <div class="hero-links" aria-label="External profiles">
    <a href="https://www.linkedin.com/in/princemanjee/" rel="noopener">LinkedIn</a>
    <span aria-hidden="true">·</span>
    <a href="https://github.com/princemanjee" rel="noopener">GitHub</a>
    <span aria-hidden="true">·</span>
    <a href="https://cv.princerehman.com" rel="noopener">CV</a>
  </div>
</GlassPanel>

<style>
  :global(.hero) {
    padding: 96px 56px;
    margin-bottom: 64px;
  }

  /*
   * Hero lockup: brand mark inline LEFT of the wordmark, vertically
   * centered with it. The mark and wordmark read as one composed
   * identity unit at the top of the hero. On narrow mobile screens
   * falls back to stacked column so the wordmark doesn't get squeezed.
   */
  .hero-lockup {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 36px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .hero-tagline {
    margin-top: 36px;
    font-family: var(--font-body);
    font-size: 22px;
    font-weight: 400;
    color: var(--color-fg-secondary);
    letter-spacing: var(--tracking-tight);
    max-width: 56ch;
  }

  .hero-description {
    margin-top: 24px;
    font-family: var(--font-body);
    font-size: 17px;
    color: var(--color-fg-tertiary);
    line-height: var(--leading-relaxed);
    max-width: 56ch;
  }

  .hero-actions {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero-links {
    margin-top: 56px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 14px;
    font-family: var(--font-body);
  }

  .hero-links a {
    color: var(--color-fg-secondary);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      border-color var(--duration-fast) var(--easing-out),
      color var(--duration-fast) var(--easing-out);
  }

  .hero-links a:hover {
    color: var(--color-fg-primary);
    border-bottom-color: var(--color-fg-primary);
  }

  .hero-links span {
    color: var(--color-fg-muted);
  }

  /* Responsive: stack tighter on mobile, smaller mark */
  @media (max-width: 768px) {
    :global(.hero) {
      padding: 64px 28px;
    }
    .hero-lockup {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
    .hero-tagline { font-size: 18px; }
    .hero-description { font-size: 15px; }
  }
</style>
