---
import BrandName from "./BrandName.astro";
import GlassButton from "./GlassButton.astro";
import GlassPanel from "./GlassPanel.astro";
---

<GlassPanel size="xl" class="hero">
  <BrandName variant="full" size="xl" as="h1" />

  <p class="hero-tagline">
    Senior Technology Consultant. AI Adoption, Digital Transformation, MIT Sloan.
  </p>

  <p class="hero-description">
    Mid-market and enterprise organizations call me when they need digital transformation
    and AI adoption done right the first time. Thirty years of building systems that stick,
    from electrons to executive strategy.
  </p>

  <div class="hero-actions">
    <GlassButton href="#work" variant="primary" size="md">
      View Selected Work
    </GlassButton>
    <GlassButton href="mailto:princemanjee@gmail.com" variant="secondary" size="md">
      Get in Touch
    </GlassButton>
  </div>

  <div class="hero-links" aria-label="External profiles">
    <a href="https://www.linkedin.com/in/princemanjee/" rel="noopener">LinkedIn</a>
    <span aria-hidden="true">·</span>
    <a href="https://github.com/princemanjee" rel="noopener">GitHub</a>
    <span aria-hidden="true">·</span>
    <a href="https://cv.princerehman.com" rel="noopener">CV</a>
  </div>
</GlassPanel>

<style>
  /* :global(.hero) targets the GlassPanel root class added via the
     `class` prop above. Component-scoped styles cannot reach into
     a child component's rendered markup without :global(). */
  :global(.hero) {
    padding: 96px 56px;
    margin-bottom: 64px;
  }

  .hero-tagline {
    margin-top: 36px;
    font-family: var(--font-body);
    font-size: 22px;
    font-weight: 400;
    color: var(--color-fg-secondary);
    letter-spacing: var(--tracking-tight);
    max-width: 56ch;
  }

  .hero-description {
    margin-top: 24px;
    font-family: var(--font-body);
    font-size: 17px;
    color: var(--color-fg-tertiary);
    line-height: var(--leading-relaxed);
    max-width: 56ch;
  }

  .hero-actions {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero-links {
    margin-top: 56px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 14px;
    font-family: var(--font-body);
  }

  .hero-links a {
    color: var(--color-fg-secondary);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      border-color var(--duration-fast) var(--easing-out),
      color var(--duration-fast) var(--easing-out);
  }

  .hero-links a:hover {
    color: var(--color-fg-primary);
    border-bottom-color: var(--color-fg-primary);
  }

  .hero-links span {
    color: var(--color-fg-muted);
  }

  @media (max-width: 768px) {
    :global(.hero) {
      padding: 64px 28px;
    }
    .hero-tagline { font-size: 18px; }
    .hero-description { font-size: 15px; }
  }
</style>
