---
/**
 * GlassButton: the page's button system.
 *
 * Three variants:
 *   primary    — royal blue lit. The default page-level call to action.
 *                Always lit (broader glow) because it should continuously
 *                draw the eye.
 *   secondary  — polished glass default, transitions to lit on hover.
 *                The supporting action. Skeuomorphic shift on hover.
 *   emerald    — emerald lit. Alternate for high-stakes actions like
 *                "Schedule a Call" where one button needs to break out.
 *
 * Three sizes: sm, md (default), lg.
 *
 * Skeuomorphic interaction:
 *   :hover    — button rises (translateY -3px) and shadow grows below.
 *               Glow intensifies. Conveys tactile lift.
 *   :active   — button depresses back toward surface (translateY -1px).
 *               Transitions faster (100ms) to feel like a physical click.
 *               Mimics pressing a real button.
 */

interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "emerald";
  size?: "sm" | "md" | "lg";
  type?: "button" | "submit" | "reset";
  class?: string;
}

const {
  href,
  variant = "secondary",
  size = "md",
  type = "button",
  class: className = "",
} = Astro.props;

const isLink = Boolean(href);
const Tag = isLink ? "a" : "button";
---

<Tag
  href={href}
  type={isLink ? undefined : type}
  class:list={[
    "glass-btn",
    `glass-btn--${variant}`,
    `glass-btn--${size}`,
    className,
  ]}>
  <slot />
</Tag>

<style>
  .glass-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-ui);
    font-weight: 500;
    color: var(--color-fg-primary);
    text-decoration: none;
    cursor: pointer;
    border: 1px solid var(--glass-border);
    transform: translateY(0);
    /* Skeuomorphic timing: easing-out matches physical inertia. */
    transition:
      transform var(--duration-slow) var(--easing-out),
      background var(--duration-slow) var(--easing-out),
      box-shadow var(--duration-slow) var(--easing-out);
  }

  /* SIZES */
  .glass-btn--sm { font-size: 13px; padding: 12px 22px; border-radius: 18px; }
  .glass-btn--md { font-size: 15px; padding: 18px 36px; border-radius: 24px; }
  .glass-btn--lg { font-size: 17px; padding: 22px 44px; border-radius: 28px; }

  /* SKEUOMORPHIC PRESS: every variant depresses on :active. */
  .glass-btn:active {
    transform: translateY(-1px);
    /* Snap shorter on press for tactile feel. */
    transition-duration: 100ms;
  }

  /* ============ SECONDARY (polished default, lit hover) ============ */

  .glass-btn--secondary {
    background: var(--glass-bg);
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    box-shadow:
      inset 0 2px 1px var(--highlight-top),
      inset 0 4px 6px var(--highlight-top-soft),
      inset 0 -2px 1px var(--highlight-bottom),
      inset 0 -4px 6px var(--highlight-bottom-soft),
      inset 3px 0 6px var(--shadow-side),
      inset -3px 0 6px var(--shadow-side),
      0 4px 12px rgba(0, 0, 0, 0.35),
      0 12px 32px rgba(0, 0, 0, 0.40),
      0 0 60px rgba(180, 210, 255, 0.12);
  }

  .glass-btn--secondary:hover {
    transform: translateY(-3px);
    background: var(--glass-bg-hover);
    box-shadow:
      inset 0 2px 1px rgba(255, 255, 255, 1),
      inset 0 4px 6px rgba(255, 255, 255, 0.35),
      inset 0 -2px 1px rgba(255, 255, 255, 0.60),
      inset 0 -4px 6px rgba(255, 255, 255, 0.15),
      inset 3px 0 6px var(--shadow-side),
      inset -3px 0 6px var(--shadow-side),
      0 6px 18px rgba(0, 0, 0, 0.40),
      0 20px 48px rgba(0, 0, 0, 0.45),
      0 0 100px rgba(180, 210, 255, 0.45),
      0 0 200px rgba(180, 210, 255, 0.25);
  }

  /* ============ PRIMARY (royal blue lit) ============ */

  .glass-btn--primary {
    background: linear-gradient(
      180deg,
      rgba(91, 140, 255, 0.95) 0%,
      rgba(59, 109, 255, 1) 50%,
      rgba(29, 74, 224, 1) 100%
    );
    border: 1px solid rgba(140, 180, 255, 0.55);
    color: white;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.40);
    box-shadow:
      inset 0 2px 1px rgba(255, 255, 255, 0.90),
      inset 0 4px 6px rgba(255, 255, 255, 0.25),
      inset 0 -2px 1px rgba(255, 255, 255, 0.30),
      inset 0 -4px 6px rgba(0, 0, 0, 0.15),
      inset 3px 0 6px var(--shadow-side),
      inset -3px 0 6px var(--shadow-side),
      0 4px 12px rgba(29, 74, 224, 0.40),
      0 12px 32px rgba(29, 74, 224, 0.45),
      0 0 80px rgba(91, 140, 255, 0.55),
      0 0 160px rgba(91, 140, 255, 0.30);
  }

  .glass-btn--primary:hover {
    transform: translateY(-3px);
    box-shadow:
      inset 0 2px 1px rgba(255, 255, 255, 1),
      inset 0 4px 6px rgba(255, 255, 255, 0.30),
      inset 0 -2px 1px rgba(255, 255, 255, 0.35),
      inset 0 -4px 6px rgba(0, 0, 0, 0.15),
      inset 3px 0 6px var(--shadow-side),
      inset -3px 0 6px var(--shadow-side),
      0 6px 18px rgba(29, 74, 224, 0.50),
      0 20px 48px rgba(29, 74, 224, 0.55),
      0 0 130px rgba(91, 140, 255, 0.80),
      0 0 240px rgba(91, 140, 255, 0.45);
  }

  /* ============ EMERALD (alternate, for high-stakes CTAs) ============ */

  .glass-btn--emerald {
    background: linear-gradient(
      180deg,
      rgba(128, 232, 165, 0.95) 0%,
      rgba(93, 191, 138, 1) 50%,
      rgba(50, 150, 100, 1) 100%
    );
    border: 1px solid rgba(180, 240, 200, 0.55);
    color: white;
    text-shadow: 0 1px 2px rgba(0, 30, 15, 0.50);
    box-shadow:
      inset 0 2px 1px rgba(255, 255, 255, 0.90),
      inset 0 4px 6px rgba(255, 255, 255, 0.25),
      inset 0 -2px 1px rgba(255, 255, 255, 0.30),
      inset 0 -4px 6px rgba(0, 30, 15, 0.20),
      inset 3px 0 6px var(--shadow-side),
      inset -3px 0 6px var(--shadow-side),
      0 4px 12px rgba(50, 150, 100, 0.45),
      0 12px 32px rgba(50, 150, 100, 0.50),
      0 0 80px rgba(93, 191, 138, 0.55),
      0 0 160px rgba(93, 191, 138, 0.30);
  }

  .glass-btn--emerald:hover {
    transform: translateY(-3px);
    box-shadow:
      inset 0 2px 1px rgba(255, 255, 255, 1),
      inset 0 4px 6px rgba(255, 255, 255, 0.30),
      inset 0 -2px 1px rgba(255, 255, 255, 0.35),
      inset 0 -4px 6px rgba(0, 30, 15, 0.20),
      inset 3px 0 6px var(--shadow-side),
      inset -3px 0 6px var(--shadow-side),
      0 6px 18px rgba(50, 150, 100, 0.55),
      0 20px 48px rgba(50, 150, 100, 0.60),
      0 0 130px rgba(93, 191, 138, 0.80),
      0 0 240px rgba(93, 191, 138, 0.45);
  }

  /* Respect reduced motion preference. */
  @media (prefers-reduced-motion: reduce) {
    .glass-btn {
      transition: none;
    }
    .glass-btn:hover,
    .glass-btn:active {
      transform: none;
    }
  }
</style>
