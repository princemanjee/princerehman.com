---
/**
 * GlassButton: the page's button system.
 *
 * Three variants:
 *   primary    — royal blue lit. The default page-level call to action.
 *                Always lit (broader glow) because it should continuously
 *                draw the eye.
 *   secondary  — polished glass default, transitions to lit on hover.
 *                The supporting action. Skeuomorphic shift on hover.
 *   emerald    — emerald lit. Alternate for high-stakes actions like
 *                "Schedule a Call" where one button needs to break out.
 *
 * Three sizes: sm, md (default), lg.
 *
 * Skeuomorphic interaction:
 *   :hover    — button rises (translateY -3px) and shadow grows below.
 *               Glow intensifies. Conveys tactile lift.
 *   :active   — button depresses back toward surface (translateY -1px).
 *               Transitions faster (100ms) to feel like a physical click.
 *               Mimics pressing a real button.
 */

interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "emerald";
  size?: "sm" | "md" | "lg";
  type?: "button" | "submit" | "reset";
  class?: string;
}

const {
  href,
  variant = "secondary",
  size = "md",
  type = "button",
  class: className = "",
} = Astro.props;

const isLink = Boolean(href);
const Tag = isLink ? "a" : "button";
---

<Tag
  href={href}
  type={isLink ? undefined : type}
  class:list={[
    "glass-btn",
    `glass-btn--${variant}`,
    `glass-btn--${size}`,
    className,
  ]}>
  <slot />
</Tag>

<style>
  .glass-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-ui);
    font-weight: 500;
    color: var(--color-fg-primary);
    text-decoration: none;
    cursor: pointer;
    border: 1px solid var(--glass-border);
    transform: translateY(0);
    /* Skeuomorphic timing: easing-out matches physical inertia. */
    transition:
      transform var(--duration-slow) var(--easing-out),
      background var(--duration-slow) var(--easing-out),
      box-shadow var(--duration-slow) var(--easing-out);
  }

  /* SIZES */
  .glass-btn--sm { font-size: 13px; padding: 12px 22px; border-radius: 18px; }
  .glass-btn--md { font-size: 15px; padding: 18px 36px; border-radius: 24px; }
  .glass-btn--lg { font-size: 17px; padding: 22px 44px; border-radius: 28px; }

  /* SKEUOMORPHIC PRESS: snap shorter on press for tactile feel. The press
   * transform itself lives in the .glass-btn:active rule near the end of the
   * file, placed after the variant :hover rules so it wins the cascade. */
  .glass-btn:active {
    transition-duration: 100ms;
  }

  /* ============ SECONDARY (polished default, lit hover) ============ */

  .glass-btn--secondary {
    background: var(--glass-bg);
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    box-shadow:
      inset 0 2px 1px var(--highlight-top),
      inset 0 4px 6px var(--highlight-top-soft),
      inset 0 -2px 1px var(--highlight-bottom),
      inset 0 -4px 6px var(--highlight-bottom-soft),
      inset 3px 0 6px var(--shadow-side),
      inset -3px 0 6px var(--shadow-side),
      0 4px 10px oklch(0 0 0 / 0.18),
      0 16px 38px oklch(0 0 0 / 0.24),
      0 0 60px var(--brand-glow);
  }

  .glass-btn--secondary:hover {
    transform: translateY(-3px) scale(1.04);
    background: var(--glass-bg-hover);
    box-shadow:
      inset 0 2px 1px var(--highlight-top),
      inset 0 4px 6px var(--highlight-top-soft),
      inset 0 -2px 1px var(--highlight-bottom),
      inset 0 -4px 6px var(--highlight-bottom-soft),
      inset 3px 0 6px var(--shadow-side),
      inset -3px 0 6px var(--shadow-side),
      0 6px 18px oklch(0 0 0 / 0.40),
      0 20px 48px oklch(0 0 0 / 0.45),
      0 0 100px var(--brand-glow),
      0 0 200px var(--brand-glow);
  }

  /* ============ PRIMARY (royal blue lit) ============ */

  .glass-btn--primary {
    background: linear-gradient(
      180deg,
      var(--accent-royal-bright) 0%,
      var(--accent-royal) 50%,
      var(--accent-royal-deep) 100%
    );
    border: 1px solid color-mix(in oklch, var(--accent-royal-bright) 55%, transparent);
    color: white;
    text-shadow: 0 1px 2px oklch(0 0 0 / 0.40);
    box-shadow:
      inset 0 2px 1px var(--highlight-top),
      inset 0 4px 6px var(--highlight-top-soft),
      inset 0 -2px 1px var(--highlight-top-soft),
      inset 0 -4px 6px oklch(0 0 0 / 0.15),
      inset 3px 0 6px var(--shadow-side),
      inset -3px 0 6px var(--shadow-side),
      0 4px 10px oklch(0 0 0 / 0.20),
      0 16px 38px color-mix(in oklch, var(--accent-royal-deep) 32%, transparent),
      0 0 80px color-mix(in oklch, var(--accent-royal-bright) 55%, transparent),
      0 0 160px color-mix(in oklch, var(--accent-royal-bright) 30%, transparent);
  }

  .glass-btn--primary:hover {
    transform: translateY(-3px) scale(1.04);
    box-shadow:
      inset 0 2px 1px var(--highlight-top),
      inset 0 4px 6px var(--highlight-top-soft),
      inset 0 -2px 1px var(--highlight-top-soft),
      inset 0 -4px 6px oklch(0 0 0 / 0.15),
      inset 3px 0 6px var(--shadow-side),
      inset -3px 0 6px var(--shadow-side),
      0 6px 18px color-mix(in oklch, var(--accent-royal-deep) 50%, transparent),
      0 20px 48px color-mix(in oklch, var(--accent-royal-deep) 55%, transparent),
      0 0 130px color-mix(in oklch, var(--accent-royal-bright) 80%, transparent),
      0 0 240px color-mix(in oklch, var(--accent-royal-bright) 45%, transparent);
  }

  /* ============ EMERALD (alternate, for high-stakes CTAs) ============ */

  .glass-btn--emerald {
    background: linear-gradient(
      180deg,
      var(--accent-emerald-bright) 0%,
      var(--accent-emerald) 50%,
      var(--accent-emerald-deep) 100%
    );
    border: 1px solid color-mix(in oklch, var(--accent-emerald-bright) 55%, transparent);
    color: white;
    text-shadow: 0 1px 2px oklch(0 0 0 / 0.50);
    box-shadow:
      inset 0 2px 1px var(--highlight-top),
      inset 0 4px 6px var(--highlight-top-soft),
      inset 0 -2px 1px var(--highlight-top-soft),
      inset 0 -4px 6px oklch(0 0 0 / 0.20),
      inset 3px 0 6px var(--shadow-side),
      inset -3px 0 6px var(--shadow-side),
      0 4px 10px oklch(0 0 0 / 0.20),
      0 16px 38px color-mix(in oklch, var(--accent-emerald-deep) 34%, transparent),
      0 0 80px color-mix(in oklch, var(--accent-emerald) 55%, transparent),
      0 0 160px color-mix(in oklch, var(--accent-emerald) 30%, transparent);
  }

  .glass-btn--emerald:hover {
    transform: translateY(-3px) scale(1.04);
    box-shadow:
      inset 0 2px 1px var(--highlight-top),
      inset 0 4px 6px var(--highlight-top-soft),
      inset 0 -2px 1px var(--highlight-top-soft),
      inset 0 -4px 6px oklch(0 0 0 / 0.20),
      inset 3px 0 6px var(--shadow-side),
      inset -3px 0 6px var(--shadow-side),
      0 6px 18px color-mix(in oklch, var(--accent-emerald-deep) 55%, transparent),
      0 20px 48px color-mix(in oklch, var(--accent-emerald-deep) 60%, transparent),
      0 0 130px color-mix(in oklch, var(--accent-emerald) 80%, transparent),
      0 0 240px color-mix(in oklch, var(--accent-emerald) 45%, transparent);
  }

  /* Press: depress / zoom out, overriding the hover lift + zoom. Defined
   * after the variant :hover rules so it wins the equal-specificity cascade
   * while pressed (the element is both :hover and :active during a click). */
  .glass-btn:active {
    transform: scale(0.95);
  }

  /* Respect reduced motion preference. */
  @media (prefers-reduced-motion: reduce) {
    .glass-btn {
      transition: none;
    }
    .glass-btn:hover,
    .glass-btn:active {
      transform: none;
    }
  }
</style>
