---
/**
 * PrismPanel: the Phase 2 four-axis control surface.
 *
 * A floating glass disc anchored to the bottom-left corner of every page.
 * Clicking it reveals the control panel exposing the four axes described
 * in the Notion spec:
 *   1. Theme mode      (Light, Dark, Hybrid, System, Neomorphic)
 *   2. Mixing model    (Analogous, Split-complementary, Complementary)
 *   3. Base hue        (0-360 slider, drag-then-commit)
 *   4. Contrast level  (AA / AAA)
 *
 * Plus a horizontal quick-select row of starter swatches and a reset
 * affordance. All control changes flow through prism-runtime.ts, which
 * generates a fresh OKLCH palette, applies it as CSS custom property
 * overrides on document.documentElement, and persists to localStorage.
 *
 * Mounted once in BaseLayout so the panel appears site-wide.
 */

import { swatches, isMono, formatMonoOklch } from "../data/prismSwatches";

const modes = [
  { id: "light",      label: "Light" },
  { id: "dark",       label: "Dark" },
  { id: "hybrid",     label: "Hybrid" },
  { id: "system",     label: "System" },
  { id: "neomorphic", label: "Neo" },
] as const;

const mixingModels = [
  { id: "analogous",           label: "Analogous" },
  { id: "split-complementary", label: "Split-comp" },
  { id: "complementary",       label: "Complement" },
] as const;
---

<div class="prism" data-prism-root>
  <button
    type="button"
    class="prism-trigger"
    aria-label="Open Prism control panel"
    aria-expanded="false"
    aria-controls="prism-panel-body"
    data-prism-trigger>
    <svg viewBox="0 0 24 24" class="prism-icon" aria-hidden="true">
      <path d="M12 3 L21 19 L3 19 Z" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linejoin="round" />
      <path d="M7 13 L17 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.55" />
      <path d="M9 16 L15 16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.30" />
    </svg>
  </button>

  <div
    id="prism-panel-body"
    class="prism-panel"
    role="dialog"
    aria-label="Prism control panel"
    aria-hidden="true"
    data-prism-panel>
    <div class="prism-panel-header">
      <span class="prism-panel-title">Prism</span>
      <span class="prism-panel-subtitle">Phase 2</span>
    </div>

    {/* Mode */}
    <section class="prism-section">
      <span class="prism-section-label">Mode</span>
      <div class="prism-segmented" role="radiogroup" aria-label="Theme mode">
        {modes.map((m) => (
          <button
            type="button"
            class="prism-segment"
            role="radio"
            aria-checked="false"
            data-prism-mode={m.id}>
            {m.label}
          </button>
        ))}
      </div>
    </section>

    {/* Mixing model */}
    <section class="prism-section">
      <span class="prism-section-label">Mixing model</span>
      <div class="prism-segmented" role="radiogroup" aria-label="Color mixing model">
        {mixingModels.map((m) => (
          <button
            type="button"
            class="prism-segment"
            role="radio"
            aria-checked="false"
            data-prism-model={m.id}>
            {m.label}
          </button>
        ))}
      </div>
    </section>

    {/* Hue slider */}
    <section class="prism-section">
      <div class="prism-section-row">
        <span class="prism-section-label">Hue</span>
        <span class="prism-section-value" data-prism-hue-display>263°</span>
      </div>
      <input
        type="range"
        min="0"
        max="360"
        step="1"
        value="263"
        class="prism-hue-slider"
        aria-label="Base hue"
        data-prism-hue
      />
      <div class="prism-hue-track" aria-hidden="true"></div>
    </section>

    {/* Contrast */}
    <section class="prism-section">
      <span class="prism-section-label">Contrast</span>
      <div class="prism-segmented" role="radiogroup" aria-label="Contrast level">
        <button type="button" class="prism-segment" role="radio" aria-checked="false" data-prism-contrast="AA">AA</button>
        <button type="button" class="prism-segment" role="radio" aria-checked="false" data-prism-contrast="AAA">AAA</button>
      </div>
    </section>

    {/* Quick-select swatches */}
    <section class="prism-section">
      <span class="prism-section-label">Swatches</span>
      <div class="prism-swatch-row">
        {swatches.map((s) => {
          const previewColor = isMono(s)
            ? formatMonoOklch(s)
            : s.groups[0]?.colors[0]?.value ?? "oklch(0.5 0.18 263)";
          return (
            <button
              type="button"
              class="prism-quick-swatch"
              title={s.name}
              aria-label={`Select ${s.name}`}
              data-prism-swatch={s.id}>
              <span class="prism-quick-swatch-chip" style={`background: ${previewColor};`} aria-hidden="true" />
            </button>
          );
        })}
      </div>
    </section>

    {/* Reset */}
    <div class="prism-panel-footer">
      <button type="button" class="prism-reset" data-prism-reset>
        Reset to defaults
      </button>
    </div>
  </div>
</div>

<script>
  import {
    init as runtimeInit,
    setUserSelection,
    resetToDefault,
    type PrismState,
  } from "../lib/prism-runtime";

  function syncUI(state: PrismState): void {
    // Mode
    document.querySelectorAll<HTMLButtonElement>("[data-prism-mode]").forEach((btn) => {
      const sel = btn.dataset.prismMode === state.mode;
      btn.setAttribute("aria-checked", sel ? "true" : "false");
      btn.classList.toggle("prism-segment--selected", sel);
    });
    // Mixing model
    document.querySelectorAll<HTMLButtonElement>("[data-prism-model]").forEach((btn) => {
      const sel = btn.dataset.prismModel === state.model;
      btn.setAttribute("aria-checked", sel ? "true" : "false");
      btn.classList.toggle("prism-segment--selected", sel);
    });
    // Contrast
    document.querySelectorAll<HTMLButtonElement>("[data-prism-contrast]").forEach((btn) => {
      const sel = btn.dataset.prismContrast === state.contrast;
      btn.setAttribute("aria-checked", sel ? "true" : "false");
      btn.classList.toggle("prism-segment--selected", sel);
    });
    // Hue
    const slider = document.querySelector<HTMLInputElement>("[data-prism-hue]");
    if (slider) slider.value = String(state.hue);
    const display = document.querySelector<HTMLElement>("[data-prism-hue-display]");
    if (display) display.textContent = `${Math.round(state.hue)}°`;
    // Swatch
    document.querySelectorAll<HTMLButtonElement>("[data-prism-swatch]").forEach((btn) => {
      const sel = btn.dataset.prismSwatch === state.swatchId;
      btn.classList.toggle("prism-quick-swatch--selected", sel);
    });
  }

  function openPanel(): void {
    const root = document.querySelector<HTMLElement>("[data-prism-root]");
    const trigger = document.querySelector<HTMLButtonElement>("[data-prism-trigger]");
    const panel = document.querySelector<HTMLElement>("[data-prism-panel]");
    if (!root || !trigger || !panel) return;
    root.classList.add("prism--open");
    trigger.setAttribute("aria-expanded", "true");
    panel.setAttribute("aria-hidden", "false");
  }

  function closePanel(): void {
    const root = document.querySelector<HTMLElement>("[data-prism-root]");
    const trigger = document.querySelector<HTMLButtonElement>("[data-prism-trigger]");
    const panel = document.querySelector<HTMLElement>("[data-prism-panel]");
    if (!root || !trigger || !panel) return;
    root.classList.remove("prism--open");
    trigger.setAttribute("aria-expanded", "false");
    panel.setAttribute("aria-hidden", "true");
  }

  function togglePanel(): void {
    const root = document.querySelector<HTMLElement>("[data-prism-root]");
    if (!root) return;
    if (root.classList.contains("prism--open")) closePanel();
    else openPanel();
  }

  function init(): void {
    // Boot the runtime: resolve schedule + persisted state + apply DOM.
    const { state } = runtimeInit();
    syncUI(state);

    const trigger = document.querySelector<HTMLButtonElement>("[data-prism-trigger]");
    trigger?.addEventListener("click", togglePanel);

    // Mode buttons
    document.querySelectorAll<HTMLButtonElement>("[data-prism-mode]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const mode = btn.dataset.prismMode as PrismState["mode"];
        if (!mode) return;
        const { state } = setUserSelection({ mode });
        syncUI(state);
      });
    });

    // Mixing model buttons
    document.querySelectorAll<HTMLButtonElement>("[data-prism-model]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const model = btn.dataset.prismModel as PrismState["model"];
        if (!model) return;
        const { state } = setUserSelection({ model });
        syncUI(state);
      });
    });

    // Contrast buttons
    document.querySelectorAll<HTMLButtonElement>("[data-prism-contrast]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const contrast = btn.dataset.prismContrast as PrismState["contrast"];
        if (!contrast) return;
        const { state } = setUserSelection({ contrast });
        syncUI(state);
      });
    });

    // Hue slider — drag for live display, commit on release.
    const slider = document.querySelector<HTMLInputElement>("[data-prism-hue]");
    const display = document.querySelector<HTMLElement>("[data-prism-hue-display]");
    if (slider && display) {
      slider.addEventListener("input", () => {
        // Preview only: update the readout. Don't regenerate the palette
        // on every input tick (commit on release per Phase 2 spec).
        display.textContent = `${slider.value}°`;
      });
      slider.addEventListener("change", () => {
        const hue = Number(slider.value);
        if (!Number.isFinite(hue)) return;
        const { state } = setUserSelection({ hue });
        syncUI(state);
      });
    }

    // Swatch quick-select
    document.querySelectorAll<HTMLButtonElement>("[data-prism-swatch]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const swatchId = btn.dataset.prismSwatch;
        if (!swatchId) return;
        const { state } = setUserSelection({ swatchId });
        syncUI(state);
      });
    });

    // Reset
    const resetBtn = document.querySelector<HTMLButtonElement>("[data-prism-reset]");
    resetBtn?.addEventListener("click", () => {
      const { state } = resetToDefault();
      syncUI(state);
    });

    // Close on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closePanel();
    });

    // Close on click outside
    document.addEventListener("click", (e) => {
      const root = document.querySelector<HTMLElement>("[data-prism-root]");
      if (!root) return;
      if (!root.classList.contains("prism--open")) return;
      if (root.contains(e.target as Node)) return;
      closePanel();
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>

<style>
  .prism {
    position: fixed;
    bottom: 20px;
    left: 20px;
    z-index: 200;
  }

  /* Trigger disc */
  .prism-trigger {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-fg-primary);
    background: var(--glass-bg-hover);
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    border: 1px solid var(--glass-border-strong);
    box-shadow:
      inset 0 1px 1px var(--highlight-top),
      inset 0 -1px 1px var(--highlight-bottom-soft),
      0 4px 16px var(--shadow-side),
      0 8px 32px var(--shadow-side);
    transition:
      transform var(--duration-base) var(--easing-out),
      background var(--duration-base) var(--easing-out),
      box-shadow var(--duration-base) var(--easing-out);
  }
  .prism-trigger:hover {
    transform: translateY(-2px);
    box-shadow:
      inset 0 1px 1px var(--highlight-top),
      inset 0 -1px 1px var(--highlight-bottom-soft),
      0 6px 20px var(--shadow-side),
      0 12px 40px var(--shadow-side),
      0 0 30px var(--brand-glow);
  }
  .prism-trigger:active { transform: translateY(0); }
  .prism-icon {
    width: 22px;
    height: 22px;
    color: var(--color-fg-primary);
  }

  /* Expanded panel */
  .prism-panel {
    position: absolute;
    bottom: calc(100% + 12px);
    left: 0;
    width: 320px;
    max-height: 70vh;
    overflow-y: auto;
    padding: var(--space-md);
    background: var(--glass-bg-hover);
    backdrop-filter: blur(calc(var(--glass-blur) * 2)) saturate(var(--glass-saturate));
    -webkit-backdrop-filter: blur(calc(var(--glass-blur) * 2)) saturate(var(--glass-saturate));
    border: 1px solid var(--glass-border-strong);
    border-radius: var(--radius-lg);
    box-shadow:
      inset 0 2px 1px var(--highlight-top),
      inset 0 -2px 1px var(--highlight-bottom),
      0 8px 24px var(--shadow-side),
      0 24px 64px var(--shadow-side),
      0 0 80px var(--brand-glow);

    opacity: 0;
    pointer-events: none;
    transform: translateY(8px) scale(0.97);
    transform-origin: bottom left;
    transition:
      opacity var(--duration-base) var(--easing-out),
      transform var(--duration-base) var(--easing-out);
  }
  .prism--open .prism-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .prism-panel-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 0 var(--space-xs) var(--space-sm);
    border-bottom: 1px solid var(--glass-border);
    margin-bottom: var(--space-xs);
  }
  .prism-panel-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-fg-primary);
    letter-spacing: var(--tracking-tight);
  }
  .prism-panel-subtitle {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-fg-muted);
  }

  /* Section */
  .prism-section {
    padding: var(--space-sm) var(--space-xs);
    border-bottom: 1px solid var(--glass-border);
  }
  .prism-section:last-of-type {
    border-bottom: none;
  }
  .prism-section-label {
    display: block;
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin-bottom: 6px;
  }
  .prism-section-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 6px;
  }
  .prism-section-row .prism-section-label { margin-bottom: 0; }
  .prism-section-value {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-fg-secondary);
    font-variant-numeric: tabular-nums;
  }

  /* Segmented selector */
  .prism-segmented {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    padding: 2px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-full);
  }
  .prism-segment {
    flex: 1;
    min-width: 0;
    padding: 4px 10px;
    border-radius: var(--radius-full);
    background: transparent;
    border: 1px solid transparent;
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    color: var(--color-fg-secondary);
    white-space: nowrap;
    transition:
      background var(--duration-fast) var(--easing-out),
      color var(--duration-fast) var(--easing-out);
  }
  .prism-segment:hover { color: var(--color-fg-primary); }
  .prism-segment--selected {
    background: linear-gradient(
      180deg,
      var(--accent-royal-bright) 0%,
      var(--accent-royal) 50%,
      var(--accent-royal-deep) 100%
    );
    color: oklch(1 0 0 / 0.98);
    box-shadow: inset 0 1px 1px var(--highlight-top);
  }

  /* Hue slider */
  .prism-hue-slider {
    width: 100%;
    height: 18px;
    margin: 0;
    appearance: none;
    -webkit-appearance: none;
    background: linear-gradient(
      to right,
      oklch(0.65 0.20 0),
      oklch(0.78 0.18 60),
      oklch(0.92 0.18 110),
      oklch(0.78 0.18 145),
      oklch(0.70 0.18 195),
      oklch(0.55 0.20 250),
      oklch(0.50 0.22 305),
      oklch(0.65 0.20 360)
    );
    border-radius: var(--radius-full);
    outline: none;
    cursor: ew-resize;
    border: 1px solid var(--glass-border-strong);
  }
  .prism-hue-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: oklch(1 0 0 / 0.95);
    border: 2px solid var(--accent-royal);
    cursor: ew-resize;
    box-shadow: 0 2px 6px oklch(0 0 0 / 0.50);
  }
  .prism-hue-slider::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: oklch(1 0 0 / 0.95);
    border: 2px solid var(--accent-royal);
    cursor: ew-resize;
    box-shadow: 0 2px 6px oklch(0 0 0 / 0.50);
  }
  .prism-hue-track { display: none; }

  /* Quick-select swatches */
  .prism-swatch-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding-top: 2px;
  }
  .prism-quick-swatch {
    width: 24px;
    height: 24px;
    padding: 0;
    background: transparent;
    border: 2px solid transparent;
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: transform var(--duration-fast) var(--easing-out);
  }
  .prism-quick-swatch:hover { transform: scale(1.1); }
  .prism-quick-swatch--selected {
    border-color: var(--color-fg-primary);
  }
  .prism-quick-swatch-chip {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-full);
    border: 1px solid oklch(0 0 0 / 0.20);
    box-shadow: inset 0 1px 1px oklch(1 0 0 / 0.30);
  }

  /* Footer with reset */
  .prism-panel-footer {
    padding: var(--space-sm) var(--space-xs) 0;
    border-top: 1px solid var(--glass-border);
    margin-top: var(--space-xs);
  }
  .prism-reset {
    width: 100%;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-fg-secondary);
    transition:
      background var(--duration-fast) var(--easing-out),
      color var(--duration-fast) var(--easing-out);
  }
  .prism-reset:hover {
    background: var(--glass-bg-hover);
    color: var(--color-fg-primary);
  }

  @media (max-width: 768px) {
    .prism { bottom: 16px; left: 16px; }
    .prism-trigger { width: 44px; height: 44px; }
    .prism-panel {
      width: min(320px, calc(100vw - 32px));
      max-height: 75vh;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .prism-trigger,
    .prism-panel,
    .prism-segment,
    .prism-quick-swatch,
    .prism-reset {
      transition: none;
    }
  }
</style>
