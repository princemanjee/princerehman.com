---
/**
 * Grid: responsive CSS grid primitive.
 *
 * Phase 1 layout primitive. Two modes:
 *   - Fixed column count: pass `columns` (1-6). Collapses to 1 on mobile.
 *   - Auto-fit: pass `min` (a CSS length). Columns auto-fit at >= min width.
 *
 * Use fixed columns for marketing layouts where you know the count up
 * front (e.g., 3-column feature grid). Use auto-fit for card grids
 * where items should reflow based on viewport.
 */

type SpaceKey = "2xs" | "xs" | "sm" | "md" | "lg" | "xl" | "2xl" | "3xl" | "4xl";

interface Props {
  columns?: 1 | 2 | 3 | 4 | 5 | 6;
  min?: string;
  gap?: SpaceKey;
  as?: "div" | "section" | "ul" | "ol";
  class?: string;
}

const {
  columns,
  min,
  gap = "lg",
  as: Tag = "div",
  class: className = "",
} = Astro.props;

const inlineStyle = min
  ? `--grid-min: ${min};`
  : undefined;
---

<Tag
  class:list={[
    "grid",
    columns && `grid--cols-${columns}`,
    min && "grid--auto",
    `grid--gap-${gap}`,
    className,
  ]}
  style={inlineStyle}>
  <slot />
</Tag>

<style>
  .grid {
    display: grid;
    width: 100%;
  }

  .grid--auto {
    grid-template-columns: repeat(auto-fit, minmax(min(var(--grid-min, 16rem), 100%), 1fr));
  }

  .grid--cols-1 { grid-template-columns: 1fr; }
  .grid--cols-2 { grid-template-columns: repeat(2, 1fr); }
  .grid--cols-3 { grid-template-columns: repeat(3, 1fr); }
  .grid--cols-4 { grid-template-columns: repeat(4, 1fr); }
  .grid--cols-5 { grid-template-columns: repeat(5, 1fr); }
  .grid--cols-6 { grid-template-columns: repeat(6, 1fr); }

  .grid--gap-2xs { gap: var(--space-2xs); }
  .grid--gap-xs  { gap: var(--space-xs); }
  .grid--gap-sm  { gap: var(--space-sm); }
  .grid--gap-md  { gap: var(--space-md); }
  .grid--gap-lg  { gap: var(--space-lg); }
  .grid--gap-xl  { gap: var(--space-xl); }
  .grid--gap-2xl { gap: var(--space-2xl); }
  .grid--gap-3xl { gap: var(--space-3xl); }
  .grid--gap-4xl { gap: var(--space-4xl); }

  /*
   * Mobile collapse: fixed-column grids fall back to single column on
   * narrow viewports. Auto-fit grids handle their own responsive flow
   * via minmax(min(var(--grid-min), 100%), 1fr) so no media query needed.
   */
  @media (max-width: 768px) {
    .grid--cols-2,
    .grid--cols-3,
    .grid--cols-4,
    .grid--cols-5,
    .grid--cols-6 {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .grid--cols-3,
    .grid--cols-4 { grid-template-columns: repeat(2, 1fr); }
    .grid--cols-5,
    .grid--cols-6 { grid-template-columns: repeat(3, 1fr); }
  }
</style>
