---
/**
 * Footer: closes out every page with brand recap, external connect links,
 * and meta information (copyright, last-updated).
 *
 * Three-column layout on desktop:
 *   Left:    Brand block (small orb mark + name + location + tagline)
 *   Middle:  Connect (LinkedIn, GitHub, CV)
 *   Right:   Contact (email, soft CTA back to engagement)
 *
 * Stacks to single column on mobile. Top border separates the footer
 * from the page content. Bottom strip carries copyright and a small
 * meta line.
 *
 * Internal navigation lives in the persistent Nav at the top of the
 * page. The footer intentionally does NOT duplicate that navigation;
 * its job is to close the page out and provide external connection
 * affordances.
 */

import BrandMark from "./BrandMark.astro";

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">
      {/* Brand block: small orb + identity */}
      <div class="footer-brand">
        <a href="/" class="footer-brand-link" aria-label="Back to home">
          <BrandMark size="md" ariaLabel="P. R. Manjee" />
          <div class="footer-brand-text">
            <div class="footer-brand-name">P. R. Manjee</div>
            <div class="footer-brand-location">Chicago, Illinois</div>
          </div>
        </a>
        <p class="footer-brand-tagline">
          Workplace Modernization through AI Adoption and Digital Transformation.
          Senior Technology Consultant for SMB, Mid-Market, and Enterprise.
        </p>
      </div>

      {/* Connect: external profile links */}
      <div class="footer-column">
        <h3 class="footer-column-heading">Connect</h3>
        <ul class="footer-link-list">
          <li>
            <a
              href="https://www.linkedin.com/in/princemanjee/"
              rel="noopener"
              class="footer-link">
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href="https://github.com/princemanjee"
              rel="noopener"
              class="footer-link">
              GitHub
            </a>
          </li>
          <li>
            <a
              href="https://cv.princerehman.com"
              rel="noopener"
              class="footer-link">
              CV
            </a>
          </li>
        </ul>
      </div>

      {/* Contact: direct paths to start a conversation */}
      <div class="footer-column">
        <h3 class="footer-column-heading">Contact</h3>
        <ul class="footer-link-list">
          <li>
            <a href="mailto:princemanjee@gmail.com" class="footer-link">
              princemanjee@gmail.com
            </a>
          </li>
          <li>
            <a href="/about" class="footer-link footer-link--cta">
              Start a conversation
              <svg viewBox="0 0 14 10" class="footer-arrow" aria-hidden="true">
                <path
                  d="M1 5 L12 5 M8 1 L12 5 L8 9"
                  stroke="currentColor"
                  stroke-width="1.4"
                  fill="none"
                  stroke-linecap="round"
                  stroke-linejoin="round" />
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </div>

    {/* Bottom strip: copyright + meta */}
    <div class="footer-meta">
      <span class="footer-copyright">
        &copy; {currentYear} P. R. Manjee. All rights reserved.
      </span>
      <span class="footer-meta-separator" aria-hidden="true">&middot;</span>
      <span class="footer-meta-updated">Site updated May 2026</span>
    </div>
  </div>
</footer>

<style>
  /*
   * Footer container: full-width band at the bottom of every page.
   * Top border creates separation from page content. Internal padding
   * provides breathing room.
   */
  .footer {
    margin-top: var(--space-4xl);
    padding: var(--space-3xl) var(--space-xl) var(--space-2xl);
    border-top: 1px solid var(--glass-border);
    background:
      linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.15) 100%);
  }

  /*
   * Inner container constrains content to the same max-width as page
   * content so the footer aligns visually with the rest of the site.
   */
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /*
   * Three-column grid: brand block on the left gets the most space
   * (1.5fr), the two link columns are equal (1fr each). On mobile this
   * collapses to a single column.
   */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--glass-border);
  }

  /* Brand block: clickable area combining mark and identity text */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .footer-brand-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    text-decoration: none;
    color: inherit;
    transition: transform var(--duration-base) var(--easing-out);
    align-self: flex-start;
  }

  .footer-brand-link:hover {
    transform: translateY(-1px);
  }

  .footer-brand-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .footer-brand-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-lg);
    line-height: 1;
    color: var(--color-fg-primary);
    letter-spacing: var(--tracking-tight);
  }

  .footer-brand-location {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: 1.2;
  }

  .footer-brand-tagline {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-fg-tertiary);
    max-width: 42ch;
    margin: 0;
  }

  /*
   * Column blocks for Connect and Contact: small uppercase heading
   * over a vertical list of links. Headings match the Geist UI label
   * styling used elsewhere (FactsPanel labels, case study section
   * headings) for visual consistency.
   */
  .footer-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .footer-column-heading {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin: 0;
  }

  .footer-link-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  /*
   * Footer link: subdued color with a hover transition that brightens
   * and adds an underline. The CTA variant has the royal blue accent
   * color and an arrow that translates on hover.
   */
  .footer-link {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-fg-secondary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition:
      color var(--duration-base) var(--easing-out),
      border-color var(--duration-base) var(--easing-out);
    display: inline-block;
  }

  .footer-link:hover {
    color: var(--color-fg-primary);
    border-bottom-color: var(--color-fg-primary);
  }

  .footer-link--cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--accent-royal-bright);
    border-bottom: none;
    font-weight: 500;
    transition: gap var(--duration-base) var(--easing-out);
  }

  .footer-link--cta:hover {
    color: var(--accent-royal-bright);
    border-bottom: none;
    gap: 10px;
  }

  .footer-arrow {
    width: 14px;
    height: 10px;
    flex-shrink: 0;
  }

  /*
   * Meta strip: small copyright and last-updated line at the very
   * bottom. Smallest font on the page, muted color.
   */
  .footer-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
  }

  .footer-meta-separator {
    color: var(--color-fg-muted);
    opacity: 0.6;
  }

  /* Tablet adjustments */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl);
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  /* Mobile: single column stack */
  @media (max-width: 768px) {
    .footer {
      padding: var(--space-2xl) var(--space-lg) var(--space-xl);
    }
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    .footer-brand {
      grid-column: auto;
    }
    .footer-brand-tagline {
      max-width: none;
    }
    .footer-meta {
      flex-direction: column;
      gap: 4px;
    }
    .footer-meta-separator {
      display: none;
    }
  }
</style>
