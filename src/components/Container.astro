---
/**
 * Container: max-width content wrapper with horizontal padding.
 *
 * Phase 1 layout primitive. Use it to constrain content to a readable
 * width and provide consistent gutters across pages.
 *
 * Sizes map to common reading widths:
 *   sm  — 640px   short-form copy, modals
 *   md  — 800px   long-form prose
 *   lg  — 1024px  general page content (default)
 *   xl  — 1200px  wider grids, case studies
 *   2xl — 1440px  full-bleed dashboards
 *
 * Pass an HTML element via `as` to render as something other than div
 * (section, article, etc.). All other props are passed through.
 */

interface Props {
  size?: "sm" | "md" | "lg" | "xl" | "2xl";
  as?: "div" | "section" | "article" | "main" | "header" | "footer";
  class?: string;
}

const { size = "lg", as: Tag = "div", class: className = "" } = Astro.props;
---

<Tag class:list={["container", `container--${size}`, className]}>
  <slot />
</Tag>

<style>
  .container {
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--space-lg);
  }

  .container--sm  { max-width: 640px; }
  .container--md  { max-width: 800px; }
  .container--lg  { max-width: 1024px; }
  .container--xl  { max-width: 1200px; }
  .container--2xl { max-width: 1440px; }

  @media (max-width: 600px) {
    .container {
      padding-inline: var(--space-md);
    }
  }
</style>
