---
/**
 * CaseStudy: a single case study panel for the Selected Work pages.
 *
 * Each case study is structured around the consulting decision-making
 * arc that prospective clients evaluate: what problem this addresses,
 * how it was approached, and where it stands now. Tech stack appears
 * as a scannable tag row beneath the body. A status-appropriate CTA
 * sits in the footer.
 *
 * Availability variants:
 *   "open-source"          → "View on GitHub" button linking to repoUrl
 *   "commercial-preserved" → "Inquire about licensing" mailto with
 *                            pre-filled subject line, plus a small
 *                            availability badge in the header
 */

import GlassPanel from "./GlassPanel.astro";
import GlassButton from "./GlassButton.astro";
import type {
  CaseStudyAvailability,
  TechDecision,
  RoleInfo,
  ScreenshotInfo,
  DownloadInfo,
} from "../data/caseStudies";

interface Props {
  title: string;
  tagline: string;
  problem: string;
  approach: string;
  status: string;
  techStack: string[];
  repoUrl?: string;
  availability?: CaseStudyAvailability;
  accentColor?: string;

  /*
   * Extended optional sections per the Notion case study spec.
   * Each is rendered conditionally so case studies that do not
   * populate these fields fall back to the basic three-section
   * format (problem/approach/status).
   */
  features?: string[];
  techDecisions?: TechDecision[];
  role?: RoleInfo;
  architectureDiagramUrl?: string;
  architectureDiagramAlt?: string;
  screenshots?: ScreenshotInfo[];
  downloads?: DownloadInfo[];

  /**
   * Layout applied as a class on the root panel. Defaults to "twopane" (the
   * chosen production layout); "standard" keeps the original single column.
   */
  layout?: "standard" | "wide" | "multicol" | "twopane";
}

const {
  title,
  tagline,
  problem,
  approach,
  status,
  techStack,
  repoUrl,
  availability = "open-source",
  accentColor,
  features,
  techDecisions,
  role,
  architectureDiagramUrl,
  architectureDiagramAlt,
  screenshots,
  downloads,
  layout = "twopane",
} = Astro.props;

const panelClass =
  layout === "standard" ? "case-study" : `case-study case-study--${layout}`;

// Split paragraphs on double newlines so callers can pass multi-paragraph
// strings naturally without requiring a parser.
const problemParas = problem.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);
const approachParas = approach.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);
const statusParas = status.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);

// CTA configuration varies by availability. Open-source case studies link
// to GitHub; commercial-preserved case studies route to a pre-filled mailto.
const ctaHref =
  availability === "commercial-preserved"
    ? `mailto:princemanjee@gmail.com?subject=${encodeURIComponent(
        `${title} — Licensing inquiry`
      )}`
    : repoUrl ?? "#";

const ctaLabel =
  availability === "commercial-preserved"
    ? "Inquire about licensing"
    : "View on GitHub";

const availabilityLabel =
  availability === "commercial-preserved"
    ? "Commercial · Code preserved"
    : "Open source";
---

<GlassPanel size="xl" class={panelClass} padded={false}>
  <header class="case-study-header">
    <div class="case-study-title-row">
      <h2 class="case-study-title" style={accentColor ? `color: ${accentColor};` : undefined}>
        {title}
      </h2>
      <span
        class:list={[
          "case-study-availability",
          `case-study-availability--${availability}`,
        ]}>
        {availabilityLabel}
      </span>
    </div>
    <p class="case-study-tagline">{tagline}</p>
  </header>

  {/* Meta rail: tech stack, downloads, CTA. Placed BEFORE the body in source
      so the two-pane layout can float it left and let the body's lower panels
      wrap to full width beneath it. Other layouts use flex `order` (set in the
      scoped styles) to restore the natural header → body → rail order. */}
  <div class="case-study-rail">
  <div class="case-study-tech">
    <div class="case-study-tech-label">Tech stack</div>
    <ul class="case-study-tech-list">
      {techStack.map((tech) => (
        <li class="case-study-tech-tag">{tech}</li>
      ))}
    </ul>
  </div>

  {downloads && downloads.length > 0 && (
    <div class="case-study-downloads">
      <div class="case-study-downloads-label">Available downloads</div>
      <ul class="case-study-downloads-list">
        {downloads.map((download) => (
          <li class="case-study-download">
            <a
              class="case-study-download-link"
              href={download.url}
              download={download.filename}
              rel="noopener">
              <span class="case-study-download-icon" aria-hidden="true">↓</span>
              <span class="case-study-download-main">
                <span class="case-study-download-label">{download.label}</span>
                {download.description && (
                  <span class="case-study-download-description">
                    {download.description}
                  </span>
                )}
              </span>
              {download.fileSize && (
                <span class="case-study-download-size">{download.fileSize}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <footer class="case-study-footer">
    <GlassButton href={ctaHref} variant="oz" size="md">
      {ctaLabel}
    </GlassButton>
  </footer>
  </div>

  <div class="case-study-body">
    <section class="case-study-section">
      <h3 class="case-study-section-heading">The problem</h3>
      {problemParas.map((p) => <p class="case-study-para">{p}</p>)}
    </section>

    {features && features.length > 0 && (
      <section class="case-study-section">
        <h3 class="case-study-section-heading">What it does</h3>
        <ul class="case-study-feature-list">
          {features.map((feat) => (
            <li class="case-study-feature-item">{feat}</li>
          ))}
        </ul>
      </section>
    )}

    <section class="case-study-section">
      <h3 class="case-study-section-heading">The approach</h3>
      {approachParas.map((p) => <p class="case-study-para">{p}</p>)}
    </section>

    {architectureDiagramUrl && (
      <section class="case-study-section">
        <h3 class="case-study-section-heading">Architecture</h3>
        <figure class="case-study-diagram">
          <img
            class="case-study-zoomable"
            src={architectureDiagramUrl}
            alt={architectureDiagramAlt ?? `${title} architecture diagram`}
            loading="lazy"
            decoding="async"
            role="button"
            tabindex="0"
            aria-label={`Enlarge ${architectureDiagramAlt ?? `${title} architecture diagram`}`}
          />
        </figure>
      </section>
    )}

    {techDecisions && techDecisions.length > 0 && (
      <section class="case-study-section">
        <h3 class="case-study-section-heading">Tech decisions and rationale</h3>
        <ul class="case-study-decisions-list">
          {techDecisions.map((decision) => (
            <li class="case-study-decision">
              <h4 class="case-study-decision-choice">{decision.choice}</h4>
              <p class="case-study-decision-rationale">{decision.rationale}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    {screenshots && screenshots.length > 0 && (
      <section class="case-study-section">
        <h3 class="case-study-section-heading">Screenshots</h3>
        <div class="case-study-screenshots">
          {screenshots.map((shot) => (
            <figure class="case-study-screenshot">
              <img
                class="case-study-zoomable"
                src={shot.src}
                alt={shot.alt}
                loading="lazy"
                decoding="async"
                role="button"
                tabindex="0"
                aria-label={`Enlarge ${shot.alt}`}
              />
              {shot.caption && (
                <figcaption class="case-study-screenshot-caption">
                  {shot.caption}
                </figcaption>
              )}
            </figure>
          ))}
        </div>
      </section>
    )}

    {role && (
      <section class="case-study-section">
        <h3 class="case-study-section-heading">
          My role <span class="case-study-role-timeframe">— {role.timeframe}</span>
        </h3>
        <p class="case-study-para">{role.description}</p>
      </section>
    )}

    <section class="case-study-section">
      <h3 class="case-study-section-heading">Status</h3>
      {statusParas.map((p) => <p class="case-study-para">{p}</p>)}
    </section>
  </div>
</GlassPanel>

<!--
  Lightbox: a single overlay reused by every zoomable image/diagram in this
  case study. Hidden until a .case-study-zoomable image is clicked. Blurred
  backdrop, enlarged image, round close button. Closes on the X, a backdrop
  click, or Escape.
-->
<div class="cs-lightbox" data-cs-lightbox hidden aria-hidden="true">
  <div class="cs-lightbox-backdrop" data-cs-lightbox-dismiss></div>
  <div class="cs-lightbox-stage" role="dialog" aria-modal="true" aria-label="Enlarged image">
    <img class="cs-lightbox-img" data-cs-lightbox-img src="" alt="" />
    <button
      type="button"
      class="cs-lightbox-close"
      data-cs-lightbox-dismiss
      aria-label="Close enlarged image"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M6 6 L18 18 M18 6 L6 18" />
      </svg>
    </button>
  </div>
</div>

<script>
  (() => {
    const lightbox = document.querySelector<HTMLElement>("[data-cs-lightbox]");
    if (!lightbox) return;
    const stageImg = lightbox.querySelector<HTMLImageElement>("[data-cs-lightbox-img]");
    if (!stageImg) return;

    let lastFocused: HTMLElement | null = null;
    let hideTimer: number | null = null;

    const open = (src: string, alt: string) => {
      // Cancel any pending hide from a just-closed instance so re-opening
      // immediately can never leave the overlay stuck in the layout.
      if (hideTimer !== null) {
        clearTimeout(hideTimer);
        hideTimer = null;
      }
      stageImg.src = src;
      stageImg.alt = alt;
      // Match the stage's aspect ratio to the image so it shrink-wraps and the
      // close button lands on the image's real corner. Natural dimensions may
      // not be ready until load (lazy-loaded images), so set both now and on
      // load. Fall back to 16:9 until known.
      const setAspect = () => {
        if (stageImg.naturalWidth && stageImg.naturalHeight) {
          lightbox.style.setProperty(
            "--cs-img-aspect",
            String(stageImg.naturalWidth / stageImg.naturalHeight),
          );
        }
      };
      if (stageImg.complete) setAspect();
      else stageImg.addEventListener("load", setAspect, { once: true });
      lightbox.hidden = false;
      lightbox.setAttribute("aria-hidden", "false");
      // Force reflow so the opacity transition runs from the hidden state.
      void lightbox.offsetWidth;
      lightbox.classList.add("is-open");
      document.body.style.overflow = "hidden";
      const closeBtn = lightbox.querySelector<HTMLElement>(".cs-lightbox-close");
      closeBtn?.focus();
    };

    const close = () => {
      lightbox.classList.remove("is-open");
      document.body.style.overflow = "";
      lightbox.setAttribute("aria-hidden", "true");
      // Hide on a fixed timer rather than waiting for transitionend, which is
      // unreliable (never fires under reduced-motion or if interrupted) and
      // would otherwise leave the overlay covering the page and eating clicks.
      if (hideTimer !== null) clearTimeout(hideTimer);
      hideTimer = window.setTimeout(() => {
        lightbox.hidden = true;
        stageImg.src = "";
        hideTimer = null;
      }, 260);
      lastFocused?.focus();
    };

    document.querySelectorAll<HTMLImageElement>(".case-study-zoomable").forEach((img) => {
      const trigger = () => {
        lastFocused = img;
        open(img.currentSrc || img.src, img.alt);
      };
      img.addEventListener("click", trigger);
      img.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          trigger();
        }
      });
    });

    lightbox.querySelectorAll<HTMLElement>("[data-cs-lightbox-dismiss]").forEach((el) => {
      el.addEventListener("click", close);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && lightbox.classList.contains("is-open")) close();
    });
  })();
</script>

<style>
  /* Zoomable images invite a click. */
  .case-study-zoomable {
    cursor: zoom-in;
  }
  .case-study-zoomable:focus-visible {
    outline: 2px solid var(--accent-royal-bright);
    outline-offset: 3px;
  }

  /* ── Lightbox ────────────────────────────────────────────────────── */
  .cs-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    opacity: 0;
    transition: opacity var(--duration-base, 240ms) var(--easing-out, ease);
  }
  .cs-lightbox.is-open {
    opacity: 1;
  }
  /* The `hidden` attribute must win over display:flex, otherwise the overlay
   * stays in the layout (invisible at opacity 0) and its backdrop intercepts
   * every click on the page. */
  .cs-lightbox[hidden] {
    display: none;
  }

  .cs-lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: oklch(0 0 0 / 0.62);
    backdrop-filter: blur(14px) saturate(120%);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
    cursor: zoom-out;
  }

  /* The stage shrink-wraps the displayed image: its aspect ratio is set from
   * the image's natural dimensions (--cs-img-aspect, written by the script),
   * and it grows to the largest box of that ratio that fits within 94vw×92vh.
   * Because the stage now matches the image bounds exactly, the close button
   * anchored to the stage corner sits on the image's actual corner (no
   * letterbox gap). The image still scales UP to fill it. */
  .cs-lightbox-stage {
    position: relative;
    aspect-ratio: var(--cs-img-aspect, 1.7778);
    width: min(92vw, calc(90vh * var(--cs-img-aspect, 1.7778)));
    height: auto;
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: scale(0.96);
    transition: transform var(--duration-base, 240ms) var(--easing-out, ease);
  }
  .cs-lightbox.is-open .cs-lightbox-stage {
    transform: scale(1);
  }

  .cs-lightbox-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 18px 50px oklch(0 0 0 / 0.55));
  }

  /* Round close button CENTERED on the image's top-right corner: its center
   * sits exactly on the corner point, so ~3/4 of it floats in the dark
   * diagonal outside the image and only its inner edge reaches the corner
   * (empty image padding, not content). top/right = -(size/2). */
  .cs-lightbox-close {
    position: absolute;
    top: -22px;
    right: -22px;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 2px solid color-mix(in oklch, var(--accent-royal-bright) 70%, white 30%);
    background: oklch(0.18 0.02 270 / 0.9);
    color: oklch(1 0 0 / 0.98);
    cursor: pointer;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    /* Steady strong accent glow under the radar-ping rings below. */
    box-shadow:
      0 4px 14px oklch(0 0 0 / 0.45),
      0 0 26px color-mix(in oklch, var(--accent-royal-bright) 85%, transparent);
    transition:
      transform var(--duration-fast, 150ms) var(--easing-out, ease),
      background var(--duration-fast, 150ms) var(--easing-out, ease);
  }

  /* Two staggered "radar ping" rings expand and fade out from the button so
   * the close affordance is unmistakable. Pseudo-elements (the X itself is an
   * <svg> child) so their scale animation never conflicts with the button's
   * own hover/press transforms. */
  .cs-lightbox-close::before,
  .cs-lightbox-close::after {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    border: 2px solid color-mix(in oklch, var(--accent-royal-bright) 80%, white 20%);
    animation: cs-close-ping 1.8s cubic-bezier(0, 0, 0.2, 1) infinite;
    pointer-events: none;
  }
  .cs-lightbox-close::after {
    animation-delay: 0.9s;
  }
  @keyframes cs-close-ping {
    0% {
      transform: scale(1);
      opacity: 0.9;
    }
    100% {
      transform: scale(2.6);
      opacity: 0;
    }
  }

  .cs-lightbox-close:hover {
    transform: scale(1.12);
    background: oklch(0.28 0.03 270 / 0.95);
  }
  .cs-lightbox-close:active {
    transform: scale(0.94);
  }
  .cs-lightbox-close svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 2.4;
    stroke-linecap: round;
    fill: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .cs-lightbox,
    .cs-lightbox-stage,
    .cs-lightbox-close {
      transition: none;
    }
    /* No ping rings, but keep a strong steady glow so the button is still
     * easy to find. */
    .cs-lightbox-close::before,
    .cs-lightbox-close::after {
      animation: none;
      opacity: 0;
    }
    .cs-lightbox-close {
      box-shadow:
        0 4px 14px oklch(0 0 0 / 0.45),
        0 0 26px color-mix(in oklch, var(--accent-royal-bright) 85%, transparent);
    }
  }

  :global(.case-study) {
    padding: var(--space-3xl);
    margin-bottom: var(--space-3xl);
    /* Flex column so the rail (moved before the body in source for the
     * two-pane float) can be re-ordered back below the body in every OTHER
     * layout. Two-pane overrides display to block to get a float context. */
    display: flex;
    flex-direction: column;
  }
  :global(.case-study) > .case-study-header { order: 0; }
  :global(.case-study) > .case-study-body   { order: 1; }
  :global(.case-study) > .case-study-rail   { order: 2; }

  /*
   * Header: project name in display serif, availability badge to the right,
   * tagline in body sans below. The badge gives an immediate signal whether
   * the visitor can clone the repo or whether this is a commercial product.
   */
  .case-study-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--glass-border);
  }

  .case-study-title-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }

  .case-study-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-4xl);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--color-fg-primary);
    margin: 0;
  }

  /*
   * Availability badge: small pill indicating the case study's status.
   * Open-source variant uses a neutral glass treatment. Commercial
   * variant uses a warmer amber accent to differentiate without being
   * loud (these are not warnings, just status indicators).
   */
  .case-study-availability {
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    padding: 5px 12px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .case-study-availability--open-source {
    color: rgba(180, 220, 200, 0.95);
    background: rgba(80, 180, 130, 0.12);
    border: 1px solid rgba(80, 180, 130, 0.30);
  }

  /*
   * On light-surfaced themes the original pale mint text washes out
   * against bright backgrounds. Darken to a readable emerald and bump
   * the surface alpha slightly so the pill still reads as a pill.
   */
  :root[data-theme="light"] .case-study-availability--open-source,
  :root[data-theme="neomorphic"] .case-study-availability--open-source {
    color: oklch(0.40 0.13 153);
    background: oklch(0.65 0.18 150 / 0.18);
    border-color: oklch(0.50 0.15 153 / 0.45);
  }

  @media (prefers-color-scheme: light) {
    :root[data-theme="system"] .case-study-availability--open-source {
      color: oklch(0.40 0.13 153);
      background: oklch(0.65 0.18 150 / 0.18);
      border-color: oklch(0.50 0.15 153 / 0.45);
    }
  }

  .case-study-availability--commercial-preserved {
    color: rgba(240, 210, 160, 0.95);
    background: rgba(220, 170, 90, 0.12);
    border: 1px solid rgba(220, 170, 90, 0.30);
  }

  /*
   * Light-surfaced themes: darken the pale-amber text to a deep amber
   * so the commercial pill stays legible against bright backgrounds.
   * Mirrors the open-source override pattern above.
   */
  :root[data-theme="light"] .case-study-availability--commercial-preserved,
  :root[data-theme="neomorphic"] .case-study-availability--commercial-preserved {
    color: oklch(0.42 0.12 75);
    background: oklch(0.75 0.14 75 / 0.22);
    border-color: oklch(0.55 0.13 75 / 0.45);
  }

  @media (prefers-color-scheme: light) {
    :root[data-theme="system"] .case-study-availability--commercial-preserved {
      color: oklch(0.42 0.12 75);
      background: oklch(0.75 0.14 75 / 0.22);
      border-color: oklch(0.55 0.13 75 / 0.45);
    }
  }

  .case-study-tagline {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--color-fg-tertiary);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    max-width: 64ch;
  }

  /*
   * Body sections: three structural blocks (problem, approach, status).
   * Each has a small uppercase label and body paragraphs. The label
   * rhythm makes the structure scannable for someone deciding whether
   * the project is relevant to their needs.
   */
  .case-study-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .case-study-section {
    margin: 0;
  }

  .case-study-section-heading {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin: 0 0 var(--space-md) 0;
  }

  /* ════════════════════════════════════════════════════════════════════
   * LAYOUT MODES (opt-in via a class on .case-study; the live /work pages
   * don't set any of these, so their default single-column layout is
   * unchanged). Used by the /layouts comparison sandbox.
   * ════════════════════════════════════════════════════════════════════ */

  /* Sections stay full-width and stacked in narrative order in EVERY mode.
   * What changes is (1) the overall width cap and (2) the long LIST sections
   * — "What it does" and "Tech decisions" — lay their items into an internal
   * grid, which is what actually uses the width and cuts the scroll, while
   * prose stays readable and the story stays in order. */
  :global(.case-study--multicol) .case-study-feature-list,
  :global(.case-study--twopane) .case-study-feature-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-md) var(--space-lg);
  }
  :global(.case-study--multicol) .case-study-feature-item,
  :global(.case-study--twopane) .case-study-feature-item {
    max-width: none;
  }
  :global(.case-study--multicol) .case-study-decisions-list,
  :global(.case-study--twopane) .case-study-decisions-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-lg);
  }
  :global(.case-study--multicol) .case-study-decision-rationale,
  :global(.case-study--twopane) .case-study-decision-rationale {
    max-width: none;
  }

