---
/**
 * CaseStudy: a single case study panel for the Selected Work page.
 *
 * Each case study is structured around the consulting decision-making
 * arc that prospective clients evaluate: what problem this addresses,
 * how I approached it, and where it stands now. Tech stack appears as
 * a scannable tag row beneath the body. A repo link sits in a footer
 * action position so the panel reads as a unit that ends in a clear
 * "go deeper" affordance.
 *
 * Props:
 *   title       — project name (rendered as h2 in display serif)
 *   tagline     — one-line description below the title
 *   problem     — paragraph or paragraphs (markdown not parsed; supply as a
 *                 single string with double newlines for paragraph breaks)
 *   approach    — paragraph or paragraphs
 *   status      — paragraph (current state, honest about what works)
 *   techStack   — array of strings rendered as small inline tags
 *   repoUrl     — link to the GitHub repository
 *   repoLabel   — text for the repo link button (default: "View on GitHub")
 *   accentColor — optional CSS color override for the title (defaults to
 *                 royal blue accent from tokens)
 */

import GlassPanel from "./GlassPanel.astro";
import GlassButton from "./GlassButton.astro";

interface Props {
  title: string;
  tagline: string;
  problem: string;
  approach: string;
  status: string;
  techStack: string[];
  repoUrl: string;
  repoLabel?: string;
  accentColor?: string;
}

const {
  title,
  tagline,
  problem,
  approach,
  status,
  techStack,
  repoUrl,
  repoLabel = "View on GitHub",
  accentColor,
} = Astro.props;

// Split paragraphs on double newlines so the caller can pass multi-paragraph
// strings naturally without requiring a parser.
const problemParas = problem.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);
const approachParas = approach.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);
const statusParas = status.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);
---

<GlassPanel size="xl" class="case-study">
  <header class="case-study-header">
    <h2 class="case-study-title" style={accentColor ? `color: ${accentColor};` : undefined}>
      {title}
    </h2>
    <p class="case-study-tagline">{tagline}</p>
  </header>

  <div class="case-study-body">
    <section class="case-study-section">
      <h3 class="case-study-section-heading">The problem</h3>
      {problemParas.map((p) => <p class="case-study-para">{p}</p>)}
    </section>

    <section class="case-study-section">
      <h3 class="case-study-section-heading">The approach</h3>
      {approachParas.map((p) => <p class="case-study-para">{p}</p>)}
    </section>

    <section class="case-study-section">
      <h3 class="case-study-section-heading">Status</h3>
      {statusParas.map((p) => <p class="case-study-para">{p}</p>)}
    </section>
  </div>

  <div class="case-study-tech">
    <div class="case-study-tech-label">Tech stack</div>
    <ul class="case-study-tech-list">
      {techStack.map((tech) => (
        <li class="case-study-tech-tag">{tech}</li>
      ))}
    </ul>
  </div>

  <footer class="case-study-footer">
    <GlassButton href={repoUrl} variant="secondary" size="md">
      {repoLabel}
    </GlassButton>
  </footer>
</GlassPanel>

<style>
  :global(.case-study) {
    padding: var(--space-3xl);
    margin-bottom: var(--space-3xl);
  }

  /*
   * Header: project name in display serif, tagline in body sans below.
   * The visual weight should feel like a chapter heading, not a card title.
   */
  .case-study-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--glass-border);
  }

  .case-study-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-4xl);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--color-fg-primary);
    margin: 0 0 var(--space-sm) 0;
  }

  .case-study-tagline {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--color-fg-tertiary);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    max-width: 64ch;
  }

  /*
   * Body sections: three structural blocks (problem, approach, status).
   * Each has a small uppercase Geist label and body Inter paragraphs.
   * The label-paragraph rhythm makes the structure scannable at a glance
   * for someone deciding whether the project is relevant to their needs.
   */
  .case-study-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .case-study-section {
    margin: 0;
  }

  .case-study-section-heading {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin: 0 0 var(--space-md) 0;
  }

  .case-study-para {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-fg-secondary);
    margin: 0 0 var(--space-md) 0;
    max-width: 72ch;
  }

  .case-study-para:last-child {
    margin-bottom: 0;
  }

  /*
   * Tech stack: a scannable row of small inline tags. Not full shields-style
   * badges (those belong on the GitHub README), just clean text chips that
   * give a quick read on the tech surface area.
   */
  .case-study-tech {
    margin-bottom: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--glass-border);
  }

  .case-study-tech-label {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin-bottom: var(--space-md);
  }

  .case-study-tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .case-study-tech-tag {
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-fg-secondary);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    padding: 6px 14px;
    white-space: nowrap;
  }

  /*
   * Footer: action area for the repo link. Single secondary button so
   * the panel ends on a clear "go deeper" affordance without competing
   * with the page-level engagement CTAs at the bottom of the page.
   */
  .case-study-footer {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* Tablet adjustments */
  @media (max-width: 1024px) {
    :global(.case-study) {
      padding: var(--space-2xl);
    }
    .case-study-title {
      font-size: var(--text-3xl);
    }
  }

  /* Mobile: tighter spacing, smaller display sizes */
  @media (max-width: 768px) {
    :global(.case-study) {
      padding: var(--space-xl);
      margin-bottom: var(--space-2xl);
    }
    .case-study-title {
      font-size: var(--text-2xl);
    }
    .case-study-tagline {
      font-size: var(--text-md);
    }
    .case-study-para {
      font-size: var(--text-base);
    }
    .case-study-body {
      gap: var(--space-lg);
    }
  }
</style>
