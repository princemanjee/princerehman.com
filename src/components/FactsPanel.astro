---
/**
 * FactsPanel: structured facts list inside a glass panel.
 *
 * Designed for the right column of two-column page layouts on About,
 * Work, and similar content pages. Renders an array of label/value
 * pairs as a definition list with consistent typography, scoped
 * within a thick-glass panel that matches the rest of the design
 * system.
 *
 * Each fact accepts either a string value or an array of strings
 * (rendered as a comma-separated inline list, useful for things
 * like "Industries: financial services, public sector, healthcare").
 *
 * Use the optional title prop to add a serif heading at the top of
 * the panel. Omit it for a more compact unstyled facts block.
 */

import GlassPanel from "./GlassPanel.astro";

export interface Fact {
  label: string;
  value: string | string[];
}

interface Props {
  facts: Fact[];
  title?: string;
}

const { facts, title } = Astro.props;
---

<GlassPanel size="md" class="facts-panel">
  {title && <h3 class="facts-panel-title">{title}</h3>}
  <dl class="facts-list">
    {facts.map((fact) => (
      <div class="fact-row">
        <dt class="fact-label">{fact.label}</dt>
        <dd class="fact-value">
          {Array.isArray(fact.value) ? fact.value.join(", ") : fact.value}
        </dd>
      </div>
    ))}
  </dl>
</GlassPanel>

<style>
  :global(.facts-panel) {
    padding: var(--space-xl);
  }

  .facts-panel-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-xl);
    color: var(--color-fg-primary);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-lg) 0;
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--glass-border);
  }

  .facts-list {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  /*
   * Each fact is a stacked label/value pair. Label is small uppercase
   * Geist UI text, value is body Inter at normal size. The vertical
   * stack reads better than a horizontal label-colon-value layout when
   * the values vary in length (some facts are one word, some are
   * comma-separated lists).
   */
  .fact-row {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .fact-label {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin: 0;
  }

  .fact-value {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 400;
    color: var(--color-fg-secondary);
    line-height: var(--leading-snug);
    margin: 0;
  }

  @media (max-width: 768px) {
    :global(.facts-panel) {
      padding: var(--space-lg);
    }
    .facts-panel-title {
      font-size: var(--text-lg);
    }
    .facts-list {
      gap: var(--space-md);
    }
  }
</style>
