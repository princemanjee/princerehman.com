---
/**
 * ThemeToggle: floating glass pill in the corner of every page.
 * Cycles light, dark, hybrid. Persists choice to localStorage.
 *
 * Phase 2 expands this into the full Prism control panel with
 * mode, mixing-model, hue slider, and contrast toggle.
 */
---

<button id="theme-toggle" aria-label="Cycle theme" type="button">
  <svg class="theme-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke-linecap="round" />
  </svg>
  <span class="theme-label" id="theme-label">hybrid</span>
</button>

<style>
  #theme-toggle {
    position: fixed;
    bottom: var(--space-lg);
    right: var(--space-lg);
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-md);
    background: var(--color-bg-elevated);
    color: var(--color-fg-primary);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-full);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    z-index: 100;
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    box-shadow: var(--shadow-md);
    transition:
      transform var(--duration-fast) var(--easing-out),
      box-shadow var(--duration-fast) var(--easing-out);
  }

  #theme-toggle:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  #theme-toggle:focus-visible {
    outline: 2px solid var(--color-brand-accent);
    outline-offset: 3px;
  }

  .theme-icon {
    width: 16px;
    height: 16px;
    color: var(--color-fg-secondary);
  }
</style>

<script>
  const button = document.getElementById("theme-toggle");
  const label = document.getElementById("theme-label");
  const themes = ["light", "dark", "hybrid"];
  const root = document.documentElement;

  function getCurrent(): string {
    const attr = root.getAttribute("data-theme");
    return attr && themes.includes(attr) ? attr : "hybrid";
  }

  function setTheme(theme: string) {
    root.setAttribute("data-theme", theme);
    if (label) label.textContent = theme;
    try {
      localStorage.setItem("prism-theme", theme);
    } catch (e) {
      // localStorage unavailable; theme will not persist across reloads.
    }
  }

  if (label) label.textContent = getCurrent();

  button?.addEventListener("click", () => {
    const current = getCurrent();
    const idx = themes.indexOf(current);
    const next = themes[(idx + 1) % themes.length];
    setTheme(next);
  });
</script>
