---
/**
 * GlassButton: action button with three variants.
 *
 * Variants:
 *   primary    Filled accent color. Use for the main CTA on a section.
 *   secondary  Frosted glass surface with border. Use for secondary actions.
 *   ghost      Text only. Use for tertiary or in-line actions.
 *
 * Sizes:
 *   sm, md (default), lg
 *
 * If href is provided, renders as <a>. Otherwise renders as <button>.
 */

interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  type?: "button" | "submit" | "reset";
}

const {
  href,
  variant = "primary",
  size = "md",
  type = "button",
} = Astro.props;

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={!href ? type : undefined}
  class:list={["glass-btn", `glass-btn--${variant}`, `glass-btn--${size}`]}
>
  <slot />
</Tag>

<style>
  .glass-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-base);
    cursor: pointer;
    transition:
      transform var(--duration-fast) var(--easing-out),
      box-shadow var(--duration-fast) var(--easing-out),
      background var(--duration-fast) var(--easing-out),
      border-color var(--duration-fast) var(--easing-out);
    text-decoration: none;
    white-space: nowrap;
  }

  .glass-btn:hover {
    transform: translateY(-1px);
    border-bottom-color: transparent;
  }

  .glass-btn:active {
    transform: translateY(0);
  }

  .glass-btn:focus-visible {
    outline: 2px solid var(--color-brand-accent);
    outline-offset: 3px;
  }

  /* Primary: filled accent. */
  .glass-btn--primary {
    background: var(--color-brand-accent);
    color: var(--color-brand-accent-fg);
    box-shadow: var(--shadow-md);
  }

  .glass-btn--primary:hover {
    box-shadow: var(--shadow-lg);
  }

  /* Secondary: glass surface with border. */
  .glass-btn--secondary {
    background: var(--color-bg-elevated);
    color: var(--color-fg-primary);
    border-color: var(--color-border-strong);
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
  }

  .glass-btn--secondary:hover {
    background: var(--color-bg-overlay);
  }

  /* Ghost: text only. */
  .glass-btn--ghost {
    background: transparent;
    color: var(--color-fg-primary);
    padding: var(--space-sm) var(--space-md);
  }

  .glass-btn--ghost:hover {
    background: var(--color-bg-elevated);
  }

  /* Sizes. */
  .glass-btn--sm {
    font-size: var(--text-sm);
    padding: var(--space-xs) var(--space-md);
  }

  .glass-btn--lg {
    font-size: var(--text-md);
    padding: var(--space-md) var(--space-xl);
  }
</style>
