# princerehman.com — environment template.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# `.env.example` is not, so it stays in version control as the canonical
# list of required vars.

# Public URL of the Cloudflare Worker that brokers Anthropic API calls
# for the Adaptive CV's JD-paste flow. Exposed to the client bundle
# because Astro's `PUBLIC_*` prefix makes a var available via
# `import.meta.env.PUBLIC_CV_GATEWAY_URL` in browser code.
#
# Provisioned by deploying the Worker in `gateway/` — see
# `gateway/README.md` for the deploy flow. The URL looks like:
#   https://princerehman-cv-gateway.<your-account>.workers.dev
PUBLIC_CV_GATEWAY_URL=
